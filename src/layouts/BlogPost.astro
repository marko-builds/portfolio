---
import BaseLayout from "./BaseLayout.astro";
import SiteNav from "../components/SiteNav.astro";

interface Props {
  title: string;
  date: Date;
  excerpt: string;
  tags: string[];
  readingTime: number;
  ogImage?: string;
}

const { title, date, excerpt, tags, readingTime, ogImage } = Astro.props;
const base = import.meta.env.BASE_URL;
const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  "headline": title,
  "description": excerpt,
  "datePublished": date.toISOString(),
  "author": {
    "@type": "Person",
    "name": "Marko Stankovic",
    "url": "https://markostankovic.org"
  },
  "publisher": {
    "@type": "Person",
    "name": "Marko Stankovic",
    "url": "https://markostankovic.org"
  }
};
---

<BaseLayout
  title={`${title} | Marko Stankovic`}
  description={excerpt}
  ogImage={ogImage}
  ogType="article"
  codeHighlighting={true}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  </Fragment>

    <style is:global>
      /* ── Reading progress bar ── */
      #reading-progress-track {
        position: fixed;
        top: 56px; /* matches navbar h-14 */
        left: 0;
        width: 100%;
        height: 3px;
        background: rgba(255,255,255,0.08);
        z-index: 10000;
        pointer-events: none;
      }
      #reading-progress-fill {
        height: 100%;
        width: 0%;
        background: var(--color-accent);
        will-change: width;
      }

      /* ── Code blocks ── */
      pre code.hljs {
        background: #141414;
        border: 1px solid #1F1F1F;
        border-radius: 0;
        font-size: 0.8125rem;
        line-height: 1.6;
        padding: 1.25rem 1.5rem;
      }

      /* ── Copy button ── */
      .pre-wrap {
        position: relative;
      }
      .copy-btn {
        position: absolute;
        top: 0.6rem;
        right: 0.6rem;
        padding: 0.25rem 0.6rem;
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.6875rem;
        background: #1F1F1F;
        color: #888888;
        border: 1px solid #2a2a2a;
        border-radius: 0;
        cursor: pointer;
        transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
        z-index: 10;
      }
      .copy-btn:hover {
        background: #2a2a2a;
        color: #F0F0F0;
        border-color: #888;
      }
      .copy-btn.copied {
        color: #5FCEDB;
        border-color: #5FCEDB20;
      }

      /* ── Long-form prose ── */
      .prose {
        font-family: 'Geist', system-ui, sans-serif;
        font-size: 1.05rem;
        line-height: 1.85;
        color: #888888;
        max-width: 680px;
      }

      .prose p {
        margin-bottom: 1.4rem;
      }

      .prose h2,
      .prose h3 {
        font-family: 'JetBrains Mono', monospace;
        color: #F0F0F0;
        margin-top: 2.5rem;
        margin-bottom: 0.75rem;
        line-height: 1.3;
      }

      .prose h2 {
        font-size: 1.3rem;
        font-weight: 600;
      }

      .prose h3 {
        font-size: 1.05rem;
        font-weight: 600;
      }

      .prose h2::before {
        content: '// ';
        color: #5FCEDB;
      }

      .prose h3::before {
        content: '// ';
        color: #5FCEDB40;
      }

      /* Inline code */
      .prose :not(pre) > code {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.875em;
        color: #5FCEDB;
        background: rgba(95, 206, 219, 0.08);
        padding: 0.15em 0.4em;
      }

      /* Code blocks: wrap in .pre-wrap via JS */
      .prose pre {
        margin-bottom: 1.5rem;
      }

      /* Blockquotes */
      .prose blockquote {
        border-left: 2px solid #5FCEDB;
        padding-left: 1.25rem;
        margin-left: 0;
        color: #888888;
        font-style: italic;
      }

      /* Images */
      .prose img {
        width: 100%;
        border: 1px solid #1F1F1F;
        display: block;
        margin: 1.5rem 0 0.5rem;
      }

      .prose figcaption {
        text-align: center;
        font-size: 0.8rem;
        font-family: 'JetBrains Mono', monospace;
        color: #444444;
        margin-bottom: 1.5rem;
      }

      /* HR */
      .prose hr {
        border: none;
        border-top: 1px solid #5FCEDB20;
        margin: 2rem 0;
      }

      /* Links */
      .prose a {
        color: #888888;
        text-decoration: underline;
        text-decoration-color: transparent;
        transition: color 0.15s ease, text-decoration-color 0.15s ease;
      }

      .prose a:hover {
        color: #5FCEDB;
        text-decoration-color: #5FCEDB40;
      }

      /* Lists */
      .prose ul,
      .prose ol {
        padding-left: 1.5rem;
        margin-bottom: 1.4rem;
      }

      .prose li {
        margin-bottom: 0.4rem;
      }

      .prose ul li::marker {
        color: #5FCEDB;
      }

      .prose ol li::marker {
        color: #444444;
        font-family: 'JetBrains Mono', monospace;
      }
    </style>


    <!-- ─── READING PROGRESS BAR ────────────────────────────────────────── -->
    <div id="reading-progress-track" aria-hidden="true">
      <div id="reading-progress-fill"></div>
    </div>

    <SiteNav active="devlog" />

    <main>
    <!-- ─── POST HERO ──────────────────────────────────────────────────────── -->
    <div class="relative pt-14">
      <div class="relative max-w-3xl mx-auto px-6 py-16">
        <a href="/devlog" class="hero-enter inline-block text-[#666666] hover:text-[#5FCEDB] font-mono text-xs mb-5 tracking-wide transition-colors duration-150" style="--delay: 0.05s">
          // devlog
        </a>

        <h1 class="hero-enter font-mono font-bold text-[#F0F0F0] mb-5" style="font-size: clamp(1.75rem, 4vw, 2.75rem); line-height: 1.1; letter-spacing: -0.02em; --delay: 0.15s">
          {title}
        </h1>

        <div class="hero-enter flex flex-wrap items-center gap-4 mb-5" style="--delay: 0.25s">
          <time datetime={date.toISOString().slice(0, 10)} class="font-mono text-sm text-[#666666]">{formattedDate}</time>
          <span class="text-[#1F1F1F]">·</span>
          <span class="font-mono text-sm text-[#666666]">{readingTime} min read</span>
        </div>

        <div class="hero-enter flex flex-wrap gap-2 mb-6" style="--delay: 0.35s">
          {tags.map(tag => (
            <span class="text-xs font-mono text-[#888888] border border-[#2A2A2A] px-3 py-1">
              {tag}
            </span>
          ))}
        </div>

        <p class="hero-enter text-[#888888] text-base leading-relaxed" style="--delay: 0.45s">
          {excerpt}
        </p>

        <div class="hero-enter mt-6 pt-6 border-t border-[#1F1F1F] flex items-center gap-2 text-sm" style="--delay: 0.5s">
          <span class="text-[#666666]">By</span>
          <a href="/" class="font-mono text-[#888888] hover:text-[#5FCEDB] transition-colors duration-150">Marko Stankovic</a>
        </div>
      </div>
    </div>

    <!-- ─── POST BODY ──────────────────────────────────────────────────────── -->
    <div class="border-t border-[#1F1F1F]/50 py-16">
      <div class="max-w-3xl mx-auto px-6">
        <article class="prose">
          <slot />
        </article>
      </div>
    </div>

    </main>

    <!-- ─── FOOTER ────────────────────────────────────────────────────────── -->
    <footer class="border-t border-[#1F1F1F]/50 py-10">
      <div class="max-w-3xl mx-auto px-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
        <a
          href="/devlog"
          class="nav-link inline-flex items-center text-sm font-mono text-[#888888] hover:text-[#5FCEDB] transition-colors duration-150"
        >
          more posts
        </a>
        <p class="text-[#666666] text-xs font-mono">© 2026 Marko Stankovic</p>
      </div>
    </footer>

    <script>
      // ── Reading progress bar ──────────────────────────────────────────────
      (function () {
        const bar = document.getElementById('reading-progress-fill');
        const article = document.querySelector('article.prose');
        if (!bar || !article) return;

        let ticking = false;

        function updateProgress() {
          const rect = article.getBoundingClientRect();
          const articleDocTop = rect.top + window.scrollY;
          const scrollable = articleDocTop + article.offsetHeight - window.innerHeight;
          const progress = scrollable > 0
            ? Math.min(Math.max(window.scrollY / scrollable, 0), 1)
            : 0;
          bar.style.width = (progress * 100) + '%';
          ticking = false;
        }

        window.addEventListener('scroll', () => {
          if (!ticking) {
            requestAnimationFrame(updateProgress);
            ticking = true;
          }
        }, { passive: true });

        // Set initial state
        updateProgress();
      })();

      // Normalise MDX fence language class so hljs uses the full grammar
      document.querySelectorAll('code.language-cs').forEach(el => {
        el.classList.remove('language-cs');
        el.classList.add('language-csharp');
      });

      // Syntax highlighting
      // @ts-ignore
      if (typeof hljs !== 'undefined') hljs.highlightAll();
      document.addEventListener('DOMContentLoaded', () => {
        // @ts-ignore
        if (typeof hljs !== 'undefined') hljs.highlightAll();
      });

      // Wrap pre blocks in .pre-wrap and add copy button
      document.addEventListener('DOMContentLoaded', () => {
        document.querySelectorAll('article.prose pre').forEach((pre) => {
          const wrap = document.createElement('div');
          wrap.className = 'pre-wrap';
          pre.parentNode?.insertBefore(wrap, pre);
          wrap.appendChild(pre);

          const btn = document.createElement('button');
          btn.className = 'copy-btn';
          btn.textContent = 'copy';
          btn.setAttribute('aria-label', 'Copy code');
          wrap.appendChild(btn);

          btn.addEventListener('click', () => {
            const code = pre.querySelector('code');
            const text = code?.textContent ?? '';
            navigator.clipboard.writeText(text).then(() => {
              btn.textContent = 'copied!';
              btn.classList.add('copied');
              setTimeout(() => {
                btn.textContent = 'copy';
                btn.classList.remove('copied');
              }, 2000);
            });
          });
        });
      });

      // Scroll reveal
      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const revealEls = document.querySelectorAll('.reveal');
      if (!prefersReduced) {
        const obs = new IntersectionObserver((entries) => {
          entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); } });
        }, { threshold: 0.1 });
        revealEls.forEach((el) => obs.observe(el));
      } else {
        revealEls.forEach((el) => el.classList.add('visible'));
      }

    </script>
</BaseLayout>
