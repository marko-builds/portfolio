---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteNav from "../../components/SiteNav.astro";
import { Image, getImage } from "astro:assets";
import screenshot1 from "../../assets/screenshots/hide-and-seek-1.png";
import screenshot2 from "../../assets/screenshots/hide-and-seek-2.png";
const base = import.meta.env.BASE_URL;
const poster1 = await getImage({ src: screenshot1, format: "webp", width: 800 });

const pageTitle = "Hide & Seek | Marko Stankovic";
const pageDescription =
  "A Unity 6 stealth game where enemy suspicion builds continuously: six NavMesh AI states, a generic StateMachine, and nine custom Level Builder editor tools.";
---

<BaseLayout title={pageTitle} description={pageDescription} codeHighlighting={true}>

  <Fragment slot="head">
    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "Hide & Seek",
      "description": "Unity 6 stealth game with NavMesh AI, a six-state generic StateMachine, continuous suspicion tracking, and nine custom Level Builder editor tools.",
      "applicationCategory": "Game",
      "applicationSubCategory": "Stealth",
      "operatingSystem": "Windows",
      "author": { "@type": "Person", "name": "Marko Stankovic", "url": "https://markostankovic.org" },
      "url": "https://markostankovic.org/projects/hide-and-seek"
    }
    </script>
  </Fragment>
    <!-- ─── NAV ─────────────────────────────────────────────────────────── -->
    <SiteNav active="work" />

    <main>
    <!-- ─── HERO ──────────────────────────────────────────────────────────── -->
    <div class="relative pt-14">
      <div class="relative max-w-5xl mx-auto px-6 py-20">
        <a
          href="/#work"
          class="hero-enter inline-block text-[#666666] hover:text-[#00FFC8] font-mono text-xs mb-6 tracking-wide transition-colors duration-150"
          style="--delay: 0.05s"
        >
          Projects
        </a>

        <div
          class="hero-enter flex flex-wrap gap-2 mb-6"
          style="--delay: 0.15s"
        >
          <span
            class="text-xs font-mono bg-cyan-400/[0.08] text-cyan-300/75 border border-cyan-400/20 px-3 py-1"
          >
            In Development
          </span>
          <span
            class="text-xs font-mono bg-cyan-400/[0.08] text-cyan-300/75 border border-cyan-400/20 px-3 py-1"
          >
            Unity 6 · URP
          </span>
        </div>

        <h1
          class="hero-enter font-mono font-bold text-[#F0F0F0] mb-5"
          style="font-size: clamp(2.5rem, 6vw, 4.5rem); line-height: 1.05; letter-spacing: -0.02em; --delay: 0.3s"
        >
          Hide &amp; Seek
        </h1>

        <p
          class="hero-enter text-[#888888] text-lg max-w-2xl leading-relaxed mb-8"
          style="--delay: 0.5s"
        >
          Detection isn't a flag. It's a continuous suspicion float with
          per-state hysteresis, six behaviours implemented as self-contained
          states in a generic <code
            class="font-mono text-[#00FFC8] text-base bg-[#00FFC8]/10 px-1.5"
            >StateMachine</code
          >, and a static noise event bus that decouples every sound source from
          every listener.
        </p>

        <div class="hero-enter flex flex-wrap gap-3" style="--delay: 0.65s">
          <a
            href="https://github.com/marko-builds/hide_and_seek_3d"
            target="_blank"
            rel="noopener noreferrer"
            class="github-link inline-flex items-center gap-2 px-5 py-2.5 bg-transparent hover:bg-cyan-400/[0.08] border border-cyan-400/15 hover:border-cyan-400/30 text-sm text-cyan-300/55 hover:text-cyan-300/75 transition-colors duration-150"
          >
            <svg
              class="w-4 h-4"
              fill="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
              ></path>
            </svg>
            View on GitHub
            <svg
              class="arrow w-4 h-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
          <a
            href="/devlog/enemy-ai-state-machine"
            class="inline-flex items-center gap-2 px-5 py-2.5 bg-transparent hover:bg-[#00FFC8]/[0.08] border border-[#00FFC8]/15 hover:border-[#00FFC8]/30 text-sm text-[#00FFC8]/55 hover:text-[#00FFC8]/75 transition-colors duration-150"
          >
            <svg
              class="w-4 h-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
              ></path>
            </svg>
            Read the devlog
            <svg
              class="arrow w-4 h-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- ─── OVERVIEW MEDIA ────────────────────────────────────────────────── -->
    <div class="border-t border-[#1F1F1F]/50 py-12">
      <div class="max-w-4xl mx-auto px-6">
        <div
          class="reveal overflow-hidden border border-[#1F1F1F] bg-[#141414]"
        >
          <video
            class="w-full aspect-video object-cover"
            data-lazy
            autoplay
            loop
            muted
            playsinline
            preload="none"
            poster={poster1.src}
          >
            <source
              src={`${base}assets/thumbnails/hide-and-seek-thumb.mp4`}
              data-src={`${base}assets/thumbnails/hide-and-seek-thumb.mp4`}
              type="video/mp4"
            />
          </video>
        </div>
        <p
          class="reveal text-[#666666] text-xs font-mono mt-3 text-center"
          style="--delay: 100ms"
        >
          Gameplay preview: suspicion build-up, patrol to investigate to chase
          sequence
        </p>
      </div>
    </div>

    <!-- ─── DETECTION AS PRESSURE ──────────────────────────────────────── -->
    <section id="detection" class="py-20 border-t border-[#1F1F1F]/50">
      <div class="max-w-5xl mx-auto px-6">
        <h2 class="reveal text-lg font-semibold text-[#F0F0F0] mb-10">
          Making Detection Feel Like Pressure, Not a Trap
        </h2>

        <div
          class="reveal max-w-3xl space-y-5 text-[#888888] leading-relaxed"
          style="--delay: 100ms"
        >
          <p>
            Binary detection (seen or unseen) removes player agency the moment
            it fires. A continuous <code
              class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1"
              >float</code
            > (0 to 100) fixes this: the player can see the meter rising, duck
            behind cover, and let it bleed back down before the enemy commits.
            Hysteresis makes that bleed-down reliable: each <code
              class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1"
              >SeekState</code
            > has separate rising and falling thresholds, so the enemy doesn't
            flicker between states at the boundary. You need to genuinely break
            line of sight to pull the meter back, not just graze the threshold.
          </p>
        </div>
      </div>
    </section>

    <!-- ─── SIX INDEPENDENT BEHAVIOURS ───────────────────────────────────── -->
    <section id="behaviours" class="py-20 border-t border-[#1F1F1F]/50">
      <div class="max-w-5xl mx-auto px-6">
        <h2 class="reveal text-lg font-semibold text-[#F0F0F0] mb-10">
          Keeping Six Behaviours Independent of Each Other
        </h2>

        <div
          class="reveal max-w-3xl space-y-5 text-[#888888] leading-relaxed"
          style="--delay: 100ms"
        >
          <p>
            Idle, Patrol, Investigate, Alert, Chase, Search: each state needs
            to read from the suspicion meter, drive the NavMesh, play
            animations, and trigger camera responses. None of those concerns
            belong in a single <code
              class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1"
              >Update()</code
            > loop. A generic <code
              class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1"
              >StateMachine</code
            > (plain C# class, no Unity dependency) paired with an <code
              class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1"
              >IState</code
            > interface makes each state a self-contained class that owns its
            own enter, tick, and exit logic. Adding a state or changing a
            transition touches one file, not the whole controller.
          </p>
        </div>
      </div>
    </section>

    <!-- ─── DECOUPLING NOISE ─────────────────────────────────────────────── -->
    <section id="noise-decoupling" class="py-20 border-t border-[#1F1F1F]/50">
      <div class="max-w-5xl mx-auto px-6">
        <h2 class="reveal text-lg font-semibold text-[#F0F0F0] mb-10">
          Decoupling Noise Sources from Listeners
        </h2>

        <div
          class="reveal max-w-3xl space-y-5 text-[#888888] leading-relaxed"
          style="--delay: 100ms"
        >
          <p>
            Anything that makes noise (a sprinting player, a knocked-over
            prop) needs to alert every enemy within range. Neither the emitter
            nor the enemy should hold a reference to the other: the set of
            listening enemies changes at runtime, and emitters shouldn't need to
            know what's listening. A static <code
              class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1"
              >NoiseEmitter</code
            > event bus with a <code
              class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1"
              >readonly struct</code
            > payload solves this. Emitters fire-and-forget. Each enemy's <code
              class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1"
              >NoiseListener</code
            > filters by <code
              class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1"
              >_hearingRadius</code
            > before raising its own local event. No allocation, no coupling, no
            broadcast-to-all overhead.
          </p>
        </div>
      </div>
    </section>

    <!-- ─── ARCHITECTURE ──────────────────────────────────────────────────── -->
    <section id="architecture" class="py-20 border-t border-[#1F1F1F]/50">
      <div class="max-w-5xl mx-auto px-6">
        <h2 class="reveal text-lg font-semibold text-[#F0F0F0] mb-10">
          Architecture
        </h2>

        <div class="space-y-14">
          <!-- Decision 1: IState + StateMachine -->
          <div class="reveal" style="--delay: 0ms">
            <div class="border border-[#1F1F1F] p-8">
              <h3 class="font-mono font-semibold text-[#F0F0F0] text-lg mb-3">
                IState + StateMachine: Plain Classes, Not MonoBehaviours
              </h3>
              <p class="text-[#888888] leading-relaxed mb-6 max-w-3xl">
                <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1"
                  >StateMachine</code
                > and <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1"
                  >BaseState</code
                > live in <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1"
                  >Infrastructure/StateMachine/</code
                > with no Unity dependency: they're plain C# classes that could
                run in a test harness without an editor. <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1"
                  >StateMachine</code
                > holds the current <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1"
                  >IState</code
                >, calls <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1"
                  >Exit()</code
                > then <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1"
                  >Enter()</code
                > on transition, and exposes <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1"
                  >Tick()</code
                >. <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1"
                  >EnemyController</code
                > owns one instance, calls <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1"
                  >Tick()</code
                > from <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1"
                  >Update()</code
                >, and constructs each concrete state with a reference to
                itself. The states get everything they need through that owner
                reference: no singletons, no <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1"
                  >FindObjectOfType</code
                >.
              </p>
              <pre><code class="language-csharp" set:text={`// Infrastructure/Interfaces/IState.cs
public interface IState
{
    void Enter();
    void Tick();
    void Exit();
}

// Infrastructure/StateMachine/StateMachine.cs
public class StateMachine
{
    IState _currentState;
    public IState CurrentState => _currentState;

    public void ChangeState(IState newState)
    {
        _currentState?.Exit();
        _currentState = newState;
        _currentState?.Enter();
    }

    public void Tick() => _currentState?.Tick();
}

// Infrastructure/StateMachine/BaseState.cs
public abstract class BaseState : IState
{
    public virtual void Enter() { }
    public virtual void Tick()  { }
    public virtual void Exit()  { }
}

// AI/Enemy/EnemyController.cs (simplified)
public class EnemyController : MonoBehaviour
{
    StateMachine _stateMachine = new();

    void Start() => _stateMachine.ChangeState(new EnemyPatrolState(this));
    void Update() => _stateMachine.Tick();

    public void ChangeState(IState newState) => _stateMachine.ChangeState(newState);
}`} /></pre>
              <!-- Concrete states -->
              <div
                class="mt-6 p-4 bg-[#0D0D0D] border border-[#1F1F1F]"
              >
                <p class="text-[#666666] text-xs font-mono mb-3">
                  Six concrete states in AI/Enemy/States/
                </p>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                  {
                    [
                      ["EnemyIdleState", "Stops navigation, waits a timer, transitions to Patrol"],
                      [
                        "EnemyPatrolState",
                        "Walks a waypoint loop, transitions to Alert or Chase as suspicion rises",
                      ],
                      [
                        "EnemyInvestigateState",
                        "Moves to a specified position, transitions back to Patrol after a look-around",
                      ],
                      [
                        "EnemyAlertState",
                        "Stops and scans toward the last-known position, transitions to Chase or Search",
                      ],
                      [
                        "EnemyChaseState",
                        "Pursues with throttled nav updates, transitions to Search on LoS loss",
                      ],
                      [
                        "EnemySearchState",
                        "Three-phase sweep: LKP, then rotate through N directions, then nearest patrol waypoints",
                      ],
                    ].map(([name, desc]) => (
                      <div class="flex gap-3 text-xs">
                        <code class="font-mono text-violet-400 shrink-0">
                          {name}
                        </code>
                        <span class="text-[#666666]">{desc}</span>
                      </div>
                    ))
                  }
                </div>
              </div>
            </div>
          </div>

          <!-- Decision 2: SuspicionMeter -->
          <div class="reveal" style="--delay: 50ms">
            <div class="border border-[#1F1F1F] p-8">
              <h3 class="font-mono font-semibold text-[#F0F0F0] text-lg mb-3">
                SuspicionMeter: Continuous Float with Hysteresis
              </h3>
              <p class="text-[#888888] leading-relaxed mb-6 max-w-3xl">
                <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1"
                  >SuspicionMeter</code
                > is a MonoBehaviour on the enemy that accumulates suspicion each
                <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1"
                  >FixedUpdate</code
                >. The visual delta from <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1"
                  >EnemyDetection.ComputeVisualDelta()</code
                > applies three modifiers: distance falloff, angle falloff, and
                a crouch stealth multiplier. The result is a per-frame rate,
                not a spike, so suspicion rises smoothly and the player has
                time to react.
              </p>
              <p class="text-[#888888] leading-relaxed mb-6 max-w-3xl">
                <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1"
                  >ComputeTargetState()</code
                > uses separate rising and falling thresholds per state. The gap
                between them is the hysteresis band: you need to lose suspicion
                past the falling threshold to revert a state, not just dip below
                the threshold that triggered it. Without that gap, a player
                hovering at the boundary would flicker the enemy between states
                on every frame.
              </p>
              <pre><code class="language-csharp" set:text={`// Detection/SuspicionMeter.cs
public class SuspicionMeter : MonoBehaviour
{
    public event Action<float>            OnSuspicionChanged;
    public event Action<SeekState, SeekState> OnStateChanged;
    public event Action                   OnPlayerCaught;

    public float     Suspicion           { get; private set; }  // 0-100
    public float     SuspicionNormalized => Suspicion / 100f;
    public SeekState State               { get; private set; }
    public float     Phase2SuspicionFloor { get; set; }         // set by LevelPhaseManager

    // Called each FixedUpdate by EnemyDetection
    public void Tick(float visualDeltaPerSec, float audioSpike,
                     bool hasLoS, float proximityDeltaPerSec,
                     bool playerInCatchRadius) { /* ... */ }

    SeekState ComputeTargetState()
    {
        // Rising thresholds (from EnemyData ScriptableObject):
        //   Unaware to Alert:     suspicion >= alertThreshold     (25f)
        //   Alert to Searching:   suspicion >= searchingThreshold (60f)
        //   Searching to Chase:   suspicion >= chaseThreshold     (85f)
        //
        // Falling thresholds (hysteresis gap prevents flickering):
        //   Chase to Searching:   suspicion < chaseRevertThreshold      (75f)
        //   Searching to Alert:   suspicion < searchingRevertThreshold  (50f)
        //   Alert to Unaware:     suspicion < alertRevertThreshold      (15f)
        // ...
    }
}

// AI/Enemy/EnemyDetection.cs: visual delta per GDD formula F2
float ComputeVisualDelta(float distance, float angleToPlayer)
{
    // distanceFactor: falloff using distanceFalloffExponent (2f) over detectionRange (15f)
    // angleFactor:    falloff using angleFalloffExponent (2f)   over fieldOfViewAngle/2 (45°)
    // crouchModifier: crouchStealthMultiplier (0.4f) when player is crouching
    // stateMultiplier: searchingVisualDetectionMultiplier (1.5f) when Searching
    return data.baseDetectionRate * distanceFactor * angleFactor
               * crouchModifier * stateMultiplier;
}`} /></pre>
            </div>
          </div>

          <!-- Decision 3: EnemyNavigation wrapper + NoiseEmitter bus -->
          <div class="reveal" style="--delay: 100ms">
            <div class="border border-[#1F1F1F] p-8">
              <h3 class="font-mono font-semibold text-[#F0F0F0] text-lg mb-3">
                EnemyNavigation: NavMeshAgent Behind an Interface
              </h3>
              <p class="text-[#888888] leading-relaxed mb-6 max-w-3xl">
                States never touch <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1"
                  >NavMeshAgent</code
                > directly. <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1"
                  >EnemyNavigation</code
                > wraps it and exposes only what states need: <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1"
                  >SetDestination()</code
                >, <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1"
                  >Stop()</code
                >, <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1"
                  >IsNear()</code
                >, and <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1"
                  >RotateToward()</code
                >. That last one is the non-obvious method: <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1"
                  >EnemyAlertState</code
                > uses it to smoothly scan toward the last-known position, and
                it returns <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1"
                  >true</code
                > when the rotation is within 1° of the target so the state
                knows when to stop waiting. Wrapping the agent means you can
                swap the navigation backend or mock it in tests without touching
                any state logic.
              </p>
              <h3 class="font-mono font-semibold text-[#F0F0F0] text-lg mb-3 mt-8">
                NoiseEmitter: Static Event Bus with Zero Allocation
              </h3>
              <p class="text-[#888888] leading-relaxed mb-6 max-w-3xl">
                <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1"
                  >NoiseEmitter</code
                > is a static class that fires a <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1"
                  >readonly struct</code
                > (<code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1"
                  >NoiseEvent</code
                >) carrying world position, intensity, and a source tag.
                Emitters call <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1"
                  >NoiseEmitter.Emit()</code
                > and forget it. Each enemy's <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1"
                  >NoiseListener</code
                > subscribes on <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1"
                  >OnEnable</code
                >, unsubscribes on <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1"
                  >OnDisable</code
                >, and filters incoming events by <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1"
                  >_hearingRadius</code
                > before raising its own local event. The struct allocates
                nothing on the heap: no boxing, no list allocation per
                broadcast. Adding a new noise source (a door slam, a
                grenade) means one <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1"
                  >Emit()</code
                > call. Nothing else changes.
              </p>
              <pre><code class="language-csharp" set:text={`// AI/Enemy/EnemyNavigation.cs
[RequireComponent(typeof(NavMeshAgent))]
public class EnemyNavigation : MonoBehaviour
{
    NavMeshAgent _agent;

    public bool IsAtDestination { get; }

    public void SetDestination(Vector3 position) => _agent.SetDestination(position);
    public void SetSpeed(float speed)            => _agent.speed = speed;
    public void Stop()                           => _agent.ResetPath();

    public bool IsNear(Vector3 position, float threshold) =>
        Vector3.Distance(transform.position, position) <= threshold;

    // Used by EnemyAlertState to scan toward last-known-position
    public bool RotateToward(Vector3 target, float degreesPerSecond) { /* returns true when < 1° */ }
}

// Detection/NoiseSystem/NoiseEvent.cs: heap-free event payload
public readonly struct NoiseEvent
{
    public Vector3 WorldPosition { get; init; }
    public float   Intensity     { get; init; }
    public string  SourceTag     { get; init; }
}

// Detection/NoiseSystem/NoiseEmitter.cs: static fire-and-forget bus
public static class NoiseEmitter
{
    public static event Action<NoiseEvent> OnNoiseEmitted;
    public static void Emit(NoiseEvent e) => OnNoiseEmitted?.Invoke(e);
}

// Detection/NoiseSystem/NoiseListener.cs: per-enemy filtered subscriber
public class NoiseListener : MonoBehaviour
{
    [SerializeField] float _hearingRadius;
    public event Action<NoiseEvent> OnNoiseHeard;

    void OnEnable()  => NoiseEmitter.OnNoiseEmitted += HandleNoise;
    void OnDisable() => NoiseEmitter.OnNoiseEmitted -= HandleNoise;

    void HandleNoise(NoiseEvent e)
    {
        if (Vector3.Distance(transform.position, e.WorldPosition) <= _hearingRadius)
            OnNoiseHeard?.Invoke(e);
    }
}`} /></pre>
