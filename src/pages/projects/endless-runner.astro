          <!-- Decision 4: PlayerController analog movement -->
          <div class="reveal" style="--delay: 150ms">
            <div class="border border-[#1F1F1F] rounded-xl p-8">
              <h3 class="font-mono font-semibold text-[#F0F0F0] text-lg mb-3">
                PlayerController — Analog X Clamping, Not Discrete Lanes
              </h3>
              <p class="text-[#888888] leading-relaxed mb-6 max-w-3xl">
                <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded"
                  >PlayerController</code
                > reads a <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded"
                  >Vector2</code
                > from <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded"
                  >InputManager.MoveEvent</code
                >, applies it to <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded"
                  >Rigidbody.MovePosition</code
                > on the X axis only, and clamps to <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded"
                  >±xClamp=3f</code
                >. The obstacles in <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded"
                  >Chunk</code
                > sit at fixed X positions (<code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded"
                  >-2.5f</code
                >, <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded"
                  >0f</code
                >, <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded"
                  >2.5f</code
                >) — the player dodges by sliding into the gap rather than
                pressing a lane key. There's no snap-to-lane: hold the stick and
                you drift to the hard edge. It also subscribes to <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded"
                  >GameManager.OnGameStart</code
                > and <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded"
                  >OnGameOver</code
                > via static events rather than holding a direct reference to <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded"
                  >GameManager</code
                > — so <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded"
                  >canControl</code
                > flips without any scene coupling.
              </p>
              <pre><code class="language-csharp" set:text={`// Player/PlayerController.cs (namespace Player)
[RequireComponent(typeof(Rigidbody))]
public class PlayerController : MonoBehaviour
{
    [SerializeField] float moveSpeed = 5f;
    [SerializeField] float xClamp    = 3f;   // hard edge at ±3 world units

    Vector2   movement;
    Rigidbody rigidBody;
    bool      canControl = false;

    void OnEnable()
    {
        // Subscribes to static events — no direct reference to InputManager scene object
        InputManager.Instance.MoveEvent   += HandleMove;
        GameManager.OnGameStart            += () => canControl = true;
        GameManager.OnGameOver             += () => canControl = false;
    }

    void HandleMove(Vector2 dir) => movement = dir;

    void FixedUpdate()
    {
        if (!canControl) return;
        HandleMovement();
    }

    void HandleMovement()
    {
        Vector3 pos = rigidBody.position;
        pos.x = Mathf.Clamp(pos.x + movement.x * moveSpeed * Time.fixedDeltaTime,
                             -xClamp, xClamp);
        rigidBody.MovePosition(pos);
    }
}

// Chunk obstacle lane positions for reference:
// float[] lanes = { -2.5f, 0f, 2.5f }  →  Chunk.cs`} /></pre>
