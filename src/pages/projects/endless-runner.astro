---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { Image, getImage } from "astro:assets";
import screenshot1 from "../../assets/screenshots/endless-runner-1.png";
import screenshot2 from "../../assets/screenshots/endless-runner-2.png";
const base = import.meta.env.BASE_URL;
const poster1 = await getImage({
  src: screenshot1,
  format: "webp",
  width: 800,
});

const pageTitle = "Endless Runner — Marko Stankovic";
const pageDescription =
  "Unity 2022 endless runner: world-scrolling procedural generation, Queue-based object pooling, and exponentially decaying difficulty escalation. Bachelor's thesis 2025.";
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  codeHighlighting={true}
>
  <Fragment slot="head">
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "Endless Runner",
        "description": "Unity 2022 endless runner with procedural level generation, object pooling, and exponential difficulty escalation. Bachelor's thesis project.",
        "applicationCategory": "Game",
        "operatingSystem": "Windows",
        "author": {
          "@type": "Person",
          "name": "Marko Stankovic",
          "url": "https://markostankovic.org"
        },
        "url": "https://markostankovic.org/projects/endless-runner"
      }
    </script>
  </Fragment>
  <!-- ─── NAV ─────────────────────────────────────────────────────────── -->
  <header
    class="fixed top-0 inset-x-0 z-50 border-b border-[#1F1F1F]/60 bg-[#0D0D0D]/80 backdrop-blur-md"
  >
    <nav class="max-w-5xl mx-auto px-6 h-14 flex items-center justify-between">
      <div class="flex items-center gap-5">
        <a
          href="/"
          class="nav-link text-sm text-[#888888] hover:text-[#00FFC8] transition-colors duration-150 flex items-center gap-1.5"
        >
          <svg
            class="w-3.5 h-3.5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M15 19l-7-7 7-7"></path>
          </svg>
          Back to Portfolio
        </a>
        <span class="text-[#1F1F1F]">|</span>
        <a
          href="/"
          class="font-bold font-mono tracking-tight text-[#F0F0F0] text-lg"
          >MS</a
        >
      </div>

      <ul class="hidden sm:flex gap-6 text-sm text-[#888888]">
        <li>
          <a
            href="/#skills"
            class="nav-link hover:text-[#F0F0F0] transition-colors duration-150"
            >Skills</a
          >
        </li>
        <li>
          <a
            href="/#projects"
            class="nav-link hover:text-[#F0F0F0] transition-colors duration-150"
            >Projects</a
          >
        </li>
        <li>
          <a
            href="/devlog"
            class="nav-link hover:text-[#F0F0F0] transition-colors duration-150"
            >Devlog</a
          >
        </li>
        <li>
          <a
            href="/#contact"
            class="nav-link hover:text-[#F0F0F0] transition-colors duration-150"
            >Let's Build</a
          >
        </li>
      </ul>

      <button
        id="menu-btn"
        class="sm:hidden w-11 h-11 flex items-center justify-center text-[#888888] hover:text-[#F0F0F0] transition-colors duration-150"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg
          id="icon-menu"
          class="w-5 h-5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
        <svg
          id="icon-close"
          class="w-5 h-5 hidden"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </nav>

    <div id="mobile-nav" aria-hidden="true">
      <div class="max-w-5xl mx-auto px-6 py-2 flex flex-col">
        <a
          href="/"
          tabindex="-1"
          class="mobile-nav-link py-3 text-sm text-[#888888] hover:text-[#00FFC8] border-b border-[#1F1F1F] transition-colors duration-150 min-h-[44px] flex items-center"
          >← Back to Portfolio</a
        >
        <a
          href="/#skills"
          tabindex="-1"
          class="mobile-nav-link py-3 text-sm text-[#888888] hover:text-[#F0F0F0] border-b border-[#1F1F1F] transition-colors duration-150 min-h-[44px] flex items-center"
          >Skills</a
        >
        <a
          href="/#projects"
          tabindex="-1"
          class="mobile-nav-link py-3 text-sm text-[#888888] hover:text-[#F0F0F0] border-b border-[#1F1F1F] transition-colors duration-150 min-h-[44px] flex items-center"
          >Projects</a
        >
        <a
          href="/devlog"
          tabindex="-1"
          class="mobile-nav-link py-3 text-sm text-[#888888] hover:text-[#F0F0F0] border-b border-[#1F1F1F] transition-colors duration-150 min-h-[44px] flex items-center"
          >Devlog</a
        >
        <a
          href="/#contact"
          tabindex="-1"
          class="mobile-nav-link py-3 text-sm text-[#888888] hover:text-[#F0F0F0] transition-colors duration-150 min-h-[44px] flex items-center"
          >Let's Build</a
        >
      </div>
    </div>
  </header>

  <main>
    <!-- ─── HERO ──────────────────────────────────────────────────────────── -->
    <div class="relative pt-14">
      <div
        class="absolute inset-0 overflow-hidden pointer-events-none"
        aria-hidden="true"
      >
        <div
          class="absolute top-1/3 right-1/4 w-[600px] h-[600px] bg-cyan-500/5 rounded-full blur-3xl"
        >
        </div>
        <div
          class="absolute top-1/2 left-1/3 w-[300px] h-[300px] bg-[#00FFC8]/3 rounded-full blur-3xl"
        >
        </div>
      </div>

      <div class="relative max-w-5xl mx-auto px-6 py-20">
        <a
          href="/#projects"
          class="hero-enter inline-block text-[#666666] hover:text-[#00FFC8] font-mono text-xs mb-6 tracking-wide transition-colors duration-150"
          style="--delay: 0.05s"
        >
          &larr; Projects
        </a>

        <div
          class="hero-enter flex flex-wrap gap-2 mb-6"
          style="--delay: 0.15s"
        >
          <span
            class="text-xs font-mono bg-[#00FFC8]/[0.08] text-[#00FFC8]/75 border border-[#00FFC8]/20 px-3 py-1 rounded-full"
          >
            Completed · Bachelor's Thesis 2025
          </span>
          <span
            class="text-xs font-mono bg-cyan-400/[0.08] text-cyan-300/75 border border-cyan-400/20 px-3 py-1 rounded-full"
          >
            Unity 2022 · URP
          </span>
        </div>

        <h1
          class="hero-enter font-mono font-bold text-[#F0F0F0] mb-5"
          style="font-size: clamp(2.5rem, 6vw, 4.5rem); line-height: 1.05; letter-spacing: -0.02em; --delay: 0.3s"
        >
          Endless Runner
        </h1>

        <p
          class="hero-enter text-[#888888] text-lg max-w-2xl leading-relaxed mb-8"
          style="--delay: 0.5s"
        >
          The world scrolls, the player stays fixed — <code
            class="font-mono text-[#00FFC8] text-base bg-[#00FFC8]/10 px-1.5 rounded"
            >LevelGenerator</code
          > moves chunks toward a stationary <code
            class="font-mono text-[#00FFC8] text-base bg-[#00FFC8]/10 px-1.5 rounded"
            >PlayerController</code
          >, each chunk self-manages its pooled obstacles in <code
            class="font-mono text-[#00FFC8] text-base bg-[#00FFC8]/10 px-1.5 rounded"
            >OnEnable/OnDisable</code
          >, and difficulty escalates via an exponentially decaying spawn
          interval.
        </p>

        <div class="hero-enter flex flex-wrap gap-3" style="--delay: 0.65s">
          <a
            href="https://github.com/Idzuo32/relic-rush"
            target="_blank"
            rel="noopener noreferrer"
            class="github-link inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-transparent hover:bg-cyan-400/[0.08] border border-cyan-400/15 hover:border-cyan-400/30 text-sm text-cyan-300/55 hover:text-cyan-300/75 transition-colors duration-150"
          >
            <svg
              class="w-4 h-4"
              fill="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
              ></path>
            </svg>
            View on GitHub
            <svg
              class="arrow w-4 h-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
          <a
            href="/devlog/object-pooling-endless-runner"
            class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-transparent hover:bg-[#00FFC8]/[0.08] border border-[#00FFC8]/15 hover:border-[#00FFC8]/30 text-sm text-[#00FFC8]/55 hover:text-[#00FFC8]/75 transition-colors duration-150"
          >
            <svg
              class="w-4 h-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
              ></path>
            </svg>
            Read the devlog
            <svg
              class="arrow w-4 h-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- ─── OVERVIEW MEDIA ────────────────────────────────────────────────── -->
    <div class="border-t border-[#1F1F1F]/50 py-12">
      <div class="max-w-4xl mx-auto px-6">
        <div
          class="reveal rounded-xl overflow-hidden border border-[#1F1F1F] bg-[#141414]"
        >
          <video
            class="w-full aspect-video object-cover"
            data-lazy
            autoplay
            loop
            muted
            playsinline
            preload="none"
            poster={poster1.src}
          >
            <source
              src={`${base}assets/thumbnails/endless-runner-thumb.mp4`}
              data-src={`${base}assets/thumbnails/endless-runner-thumb.mp4`}
              type="video/mp4"
            />
          </video>
        </div>
        <p
          class="reveal text-[#666666] text-xs font-mono mt-3 text-center"
          style="--delay: 100ms"
        >
          Gameplay preview — world scrolling, obstacle pool recycling,
          checkpoint difficulty spike
        </p>
      </div>
    </div>

    <!-- ─── KEEPING OBJECT COUNT CONSTANT ────────────────────────────────── -->
    <section id="object-count" class="py-20 border-t border-[#1F1F1F]/50">
      <div class="max-w-5xl mx-auto px-6">
        <h2 class="reveal text-lg font-semibold text-[#F0F0F0] mb-10">
          Keeping Object Count Constant at Runtime
        </h2>

        <div
          class="reveal max-w-3xl space-y-5 text-[#888888] leading-relaxed"
          style="--delay: 100ms"
        >
          <p>
            Spawning a new prefab for every obstacle means a GC allocation every
            time one appears — and at higher speeds those pauses are noticeable.
            A <code
              class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded"
              >Queue</code
            >-based <code
              class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded"
              >ObjectPool</code
            >, managed by a static <code
              class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded"
              >PoolManager</code
            > keyed by prefab, pre-warms instances at load time and recycles without
            calling <code
              class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded"
              >Instantiate</code
            > again during play. Each <code
              class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded"
              >PooledObject</code
            > component acts as a type tag so <code
              class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded"
              >PoolManager.Release()</code
            > can recursively return a chunk and all its children in one call — the
            caller doesn't need to know what's inside the chunk.
          </p>
        </div>
      </div>
    </section>

    <!-- ─── INVERTING MOTION ─────────────────────────────────────────────── -->
    <section id="inverting-motion" class="py-20 border-t border-[#1F1F1F]/50">
      <div class="max-w-5xl mx-auto px-6">
        <h2 class="reveal text-lg font-semibold text-[#F0F0F0] mb-10">
          Inverting Motion to Sidestep Float Precision
        </h2>

        <div
          class="reveal max-w-3xl space-y-5 text-[#888888] leading-relaxed"
          style="--delay: 100ms"
        >
          <p>
            Moving the player forward accumulates floating-point error over long
            runs, and you still need a camera-follow system. The simpler fix:
            keep <code
              class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded"
              >PlayerController</code
            > at a fixed world position and move the world toward it. <code
              class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded"
              >LevelGenerator</code
            > translates every active chunk by <code
              class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded"
              >-Vector3.forward * moveSpeed * dt</code
            > each frame and recycles via <code
              class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded"
              >PoolManager.Release()</code
            > when a chunk clears the camera. One direction, one transform operation,
            no precision drift.
          </p>
        </div>
      </div>
    </section>

    <!-- ─── SHAPING DIFFICULTY ───────────────────────────────────────────── -->
    <section id="difficulty-curve" class="py-20 border-t border-[#1F1F1F]/50">
      <div class="max-w-5xl mx-auto px-6">
        <h2 class="reveal text-lg font-semibold text-[#F0F0F0] mb-10">
          Shaping Difficulty as a Curve, Not a Step Function
        </h2>

        <div
          class="reveal max-w-3xl space-y-5 text-[#888888] leading-relaxed"
          style="--delay: 100ms"
        >
          <p>
            Linear difficulty — "add one obstacle every N checkpoints" —
            produces a staircase the player can feel as sudden jumps.
            Exponential decay gives you the opposite: early checkpoints bite
            hard, late ones barely tighten the interval. Each <code
              class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded"
              >Checkpoint</code
            > decreases <code
              class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded"
              >ObstacleSpawner.obstacleSpawnTime</code
            > by a decaying amount, so the game front-loads pressure and asymptotically
            approaches a minimum spawn interval rather than reaching it abruptly.
            Speed increases couple directly to <code
              class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded"
              >Physics.gravity.z</code
            > and camera FOV, so the player reads faster as a physical sensation,
            not just a number.
          </p>
        </div>
      </div>
    </section>

    <!-- ─── ARCHITECTURE ──────────────────────────────────────────────────── -->
    <section id="architecture" class="py-20 border-t border-[#1F1F1F]/50">
      <div class="max-w-5xl mx-auto px-6">
        <h2 class="reveal text-lg font-semibold text-[#F0F0F0] mb-10">
          Architecture
        </h2>

        <div class="space-y-14">
          <!-- Decision 1: LevelGenerator + Chunk -->
          <div class="reveal" style="--delay: 0ms">
            <div class="border border-[#1F1F1F] rounded-xl p-8">
              <h3 class="font-mono font-semibold text-[#F0F0F0] text-lg mb-3">
                LevelGenerator + Chunk — World Scrolls, Player Stays Fixed
              </h3>
              <p class="text-[#888888] leading-relaxed mb-6 max-w-3xl">
                <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded"
                  >LevelGenerator</code
                > owns a <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded"
                  >List&lt;GameObject&gt;</code
                > of active chunks, moves them each frame, and calls <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded"
                  >PoolManager.Release()</code
                > on the rearmost chunk when it clears the camera. Every <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded"
                  >checkpointChunkInterval</code
                >-th spawn substitutes a <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded"
                  >checkpointChunkPrefab</code
                > for a standard chunk — no external timer, just a modulo check on
                <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded"
                  >chunksSpawned</code
                >. Each <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded"
                  >Chunk</code
                > is fully self-contained: <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded"
                  >OnEnable</code
                > spawns its fences, apple, and coins; <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded"
                  >OnDisable</code
                > is a safety cleanup. No external system coordinates a chunk's contents
                — the chunk owns its own lifecycle entirely.
              </p>
              <pre><code class="language-csharp" set:text={`// Proc Gen/LevelGenerator.cs (namespace ProceduralGeneration)
public class LevelGenerator : MonoBehaviour
{
    [SerializeField] GameObject[]  chunkPrefabs;
    [SerializeField] GameObject    checkpointChunkPrefab;
    [SerializeField] int           startingChunksAmount = 12;
    [SerializeField] int           checkpointChunkInterval = 8;
    [SerializeField] float         chunkLength = 10f;

    float moveSpeed = 10f;
    readonly List<GameObject> chunks = new();
    int chunksSpawned;

    void Update()
    {
        MoveChunks();
        if (ChunkPassedCamera()) RecycleAndSpawn();
    }

    void MoveChunks()
    {
        foreach (var chunk in chunks)
            chunk.transform.position -= Vector3.forward * moveSpeed * Time.deltaTime;
    }

    GameObject ChooseChunkToSpawn() =>
        chunksSpawned % checkpointChunkInterval == 0
            ? checkpointChunkPrefab
            : chunkPrefabs[Random.Range(0, chunkPrefabs.Length)];

    void SpawnChunk()
    {
        var prefab = ChooseChunkToSpawn();
        var go     = PoolManager.Get(prefab, SpawnPosition(), Quaternion.identity);
        chunks.Add(go);
        chunksSpawned++;
    }

    void RecycleAndSpawn()
    {
        PoolManager.Release(chunks[0]);  // recursive — releases chunk + all children
        chunks.RemoveAt(0);
        SpawnChunk();
    }
}

// Proc Gen/Chunk.cs — self-managing content lifecycle
public class Chunk : MonoBehaviour
{
    float[] lanes = { -2.5f, 0f, 2.5f };  // three fixed X-axis lanes

    void OnEnable()   // called when pool hands this chunk out
    {
        SpawnFences();   // up to 2, random lane selection without replacement
        SpawnApple();    // appleSpawnChance = 0.3f
        SpawnCoins();    // coinSpawnChance  = 0.5f, up to 6 in a line
    }

    void OnDisable()  // called when PoolManager.Release() deactivates this chunk
    {
        // PoolManager.Release() already handles recursive child release
        // clearing the spawnRoot children here is a safety cleanup
    }
}`} /></pre>
            </div>
          </div>

          <!-- Decision 2: ObjectPool + PoolManager + PooledObject -->
          <div class="reveal" style="--delay: 50ms">
            <div class="border border-[#1F1F1F] rounded-xl p-8">
              <h3 class="font-mono font-semibold text-[#F0F0F0] text-lg mb-3">
                ObjectPool + PoolManager + PooledObject — Queue-Based, Keyed by
                Prefab
              </h3>
              <p class="text-[#888888] leading-relaxed mb-6 max-w-3xl">
                <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded"
                  >ObjectPool</code
                > is a plain class — not a <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded"
                  >MonoBehaviour</code
                > — using a <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded"
                  >Queue&lt;GameObject&gt;</code
                > for FIFO recycling. The static <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded"
                  >PoolManager</code
                > maps each prefab to its pool and creates pools on first access with
                no pre-registration step.
              </p>
              <p class="text-[#888888] leading-relaxed mb-6 max-w-3xl">
                The key detail is <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded"
                  >PooledObject</code
                >. It's stamped onto every instance as a component tag during <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded"
                  >CreateInstance()</code
                >, storing the originating prefab as a key. This is what enables
                recursive release: when you call <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded"
                  >PoolManager.Release()</code
                > on a chunk, it iterates the chunk's children, returns any <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded"
                  >PooledObject</code
                > children to their own pools first, then returns the chunk itself.
                The caller passes one <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded"
                  >GameObject</code
                > — the pool handles the rest.
              </p>
              <pre><code class="language-csharp" set:text={`// Pooling/ObjectPool.cs (namespace Pooling) — plain class, not MonoBehaviour
public class ObjectPool
{
    readonly GameObject        _prefab;
    readonly Transform         _poolRoot;
    readonly Queue<GameObject> _items = new();

    public ObjectPool(GameObject prefab, Transform poolRoot, int prewarm = 0)
    {
        _prefab   = prefab;
        _poolRoot = poolRoot;
        for (int i = 0; i < prewarm; i++) _items.Enqueue(CreateInstance());
    }

    public GameObject Get(Vector3 position, Quaternion rotation, Transform parent)
    {
        var go = _items.Count > 0 ? _items.Dequeue() : CreateInstance();
        go.transform.SetPositionAndRotation(position, rotation);
        go.transform.SetParent(parent);
        go.SetActive(true);
        return go;
    }

    public void Return(GameObject go)
    {
        go.SetActive(false);
        go.transform.SetParent(_poolRoot);
        _items.Enqueue(go);
    }

    GameObject CreateInstance()
    {
        var go = Object.Instantiate(_prefab, _poolRoot);
        go.SetActive(false);
        if (!go.TryGetComponent<PooledObject>(out _))
            go.AddComponent<PooledObject>().PrefabKey = _prefab;
        return go;
    }
}

// Managers/PoolManager.cs — static registry, one pool per prefab
public static class PoolManager
{
    static readonly Dictionary<GameObject, ObjectPool> Pools = new();
    static Transform _root;
    static Transform Root   // lazy DontDestroyOnLoad container
    {
        get
        {
            if (_root == null)
            {
                _root = new GameObject("[PoolManager]").transform;
                Object.DontDestroyOnLoad(_root.gameObject);
            }
            return _root;
        }
    }

    public static GameObject Get(GameObject prefab, Vector3 pos, Quaternion rot,
                                  Transform parent = null)
    {
        if (!Pools.TryGetValue(prefab, out var pool))
            Pools[prefab] = pool = new ObjectPool(prefab, Root);
        return pool.Get(pos, rot, parent);
    }

    public static void Release(GameObject go)
    {
        // Recursively release pooled children before returning parent
        foreach (Transform child in go.transform)
            ReleaseIfPooled(child.gameObject);

        if (go.TryGetComponent<PooledObject>(out var pooled))
            Pools[pooled.PrefabKey].Return(go);
    }
}`} /></pre>
            </div>
          </div>

          <!-- Decision 3: Difficulty escalation -->
          <div class="reveal" style="--delay: 100ms">
            <div class="border border-[#1F1F1F] rounded-xl p-8">
              <h3 class="font-mono font-semibold text-[#F0F0F0] text-lg mb-3">
                Difficulty Escalation — Checkpoints, Gravity, and Exponential
                Decay
              </h3>
              <p class="text-[#888888] leading-relaxed mb-6 max-w-3xl">
                Each <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded"
                  >Checkpoint</code
                > trigger fires two calls: <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded"
                  >GameManager.IncreaseTime()</code
                > extends the run, and <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded"
                  >ObstacleSpawner.DecreaseObstacleSpawnTime()</code
                > tightens the spawn interval. The interesting part is <em
                  >how</em
                >
                it tightens: exponential decay rather than a fixed decrement. The
                first checkpoint removes a large slice from the interval; each subsequent
                one removes less. Concretely, <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded"
                  >currentDecreaseAmount</code
                > gets multiplied by <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded"
                  >decayRate</code
                > (0.8) every time — so checkpoint one hits for <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded"
                  >0.1f</code
                >, checkpoint two for <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded"
                  >0.08f</code
                >, and so on down to the <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded"
                  >minimumDecreaseAmount</code
                > floor. The player feels early pressure but the game never becomes
                mechanically impossible.
              </p>
              <p class="text-[#888888] leading-relaxed mb-6 max-w-3xl">
                Speed increases go through <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded"
                  >ApplySpeedDelta()</code
                >, which remaps <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded"
                  >moveSpeed</code
                > to a <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded"
                  >Physics.gravity.z</code
                > value and calls <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1 rounded"
                  >CameraController.ChangeCameraFOV()</code
                >. Faster world = stronger Z pull = wider FOV — three systems
                agreeing that something has changed, so the player reads it as a
                physical reality rather than a stat update.
              </p>
              <pre><code class="language-csharp" set:text={`// Proc Gen/ObstacleSpawner.cs
public class ObstacleSpawner : MonoBehaviour
{
    [SerializeField] float obstacleSpawnTime    = 1f;
    [SerializeField] float minObstacleSpawnTime = 0.2f;
    [SerializeField] float initialDecreaseAmount = 0.1f;
    [SerializeField] float decayRate             = 0.8f;
    [SerializeField] float minimumDecreaseAmount = 0.01f;

    float currentDecreaseAmount;

    void Start() => currentDecreaseAmount = initialDecreaseAmount;

    // Called by Checkpoint.OnTriggerEnter() each time the player passes a checkpoint
    public void DecreaseObstacleSpawnTime()
    {
        obstacleSpawnTime = Mathf.Max(obstacleSpawnTime - currentDecreaseAmount,
                                      minObstacleSpawnTime);
        // Exponential decay: each call has less impact than the last
        currentDecreaseAmount = Mathf.Max(currentDecreaseAmount * decayRate,
                                           minimumDecreaseAmount);
    }
}

// Proc Gen/Checkpoint.cs
public class Checkpoint : MonoBehaviour
{
    [SerializeField] float checkpointTimeExtension = 5f;

    void OnTriggerEnter(Collider other)
    {
        GameManager.Instance.IncreaseTime(checkpointTimeExtension);
        _obstacleSpawner.DecreaseObstacleSpawnTime();
    }
}

// Proc Gen/LevelGenerator.cs — speed coupled to gravity + FOV
float ApplySpeedDelta(float delta)
{
    float clamped = Mathf.Clamp(moveSpeed + delta, minMoveSpeed, maxMoveSpeed);
    float applied = clamped - moveSpeed;
    moveSpeed     = clamped;

    // Remap speed to gravity.z — faster world = stronger Z pull
    float t = Mathf.InverseLerp(minMoveSpeed, maxMoveSpeed, moveSpeed);
    Physics.gravity = new Vector3(0, Physics.gravity.y,
                                  Mathf.Lerp(minGravityZ, maxGravityZ, t));
    cameraController.ChangeCameraFOV(applied);
    return applied;
}`} /></pre>
