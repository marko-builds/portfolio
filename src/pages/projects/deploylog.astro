---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteNav from "../../components/SiteNav.astro";
import { Image, getImage } from "astro:assets";
import screenshot1 from "../../assets/screenshots/deploylog-1.png";
const poster1 = await getImage({
  src: screenshot1,
  format: "webp",
  width: 1200,
});

const pageTitle = "DeployLog | Marko Stankovic";
const pageDescription =
  "DeployLog: a changelog & release-notes platform for dev teams. Next.js 16 + Supabase + Stripe, an embeddable widget, a published npm CLI, and a GitHub Action, with AI-generated release notes.";
---

<BaseLayout title={pageTitle} description={pageDescription} codeHighlighting={true}>
  <Fragment slot="head">
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "DeployLog",
        "description": "Changelog and release-notes platform for developers and small teams: hosted page, embeddable widget, npm CLI, and GitHub Action, with AI-generated release notes.",
        "applicationCategory": "DeveloperApplication",
        "operatingSystem": "Web",
        "author": {
          "@type": "Person",
          "name": "Marko Stankovic",
          "url": "https://markostankovic.org"
        },
        "url": "https://markostankovic.org/projects/deploylog"
      }
    </script>
  </Fragment>

  <!-- ─── NAV ─────────────────────────────────────────────────────────── -->
  <SiteNav active="work" />

  <main>
    <!-- ─── HERO ──────────────────────────────────────────────────────────── -->
    <div class="relative pt-14">
      <div class="relative max-w-5xl mx-auto px-6 py-20">
        <a
          href="/#work"
          class="hero-enter inline-block text-[#666666] hover:text-[#00FFC8] font-mono text-xs mb-6 tracking-wide transition-colors duration-150"
          style="--delay: 0.05s"
        >
          Projects
        </a>

        <div class="hero-enter flex flex-wrap gap-2 mb-6" style="--delay: 0.15s">
          <span
            class="text-xs font-mono bg-[#00FFC8]/[0.08] text-[#00FFC8]/75 border border-[#00FFC8]/20 px-3 py-1"
          >
            Launching · solo, full-stack
          </span>
          <span
            class="text-xs font-mono bg-cyan-400/[0.08] text-cyan-300/75 border border-cyan-400/20 px-3 py-1"
          >
            Next.js · Supabase · Stripe
          </span>
        </div>

        <h1
          class="hero-enter font-mono font-bold text-[#F0F0F0] mb-5"
          style="font-size: clamp(2.5rem, 6vw, 4.5rem); line-height: 1.05; letter-spacing: -0.02em; --delay: 0.3s"
        >
          DeployLog
        </h1>

        <p
          class="hero-enter text-[#888888] text-lg max-w-2xl leading-relaxed mb-8"
          style="--delay: 0.5s"
        >
          Keeping a changelog current is the chore every dev team drops first.
          DeployLog makes it automatic: publish entries to a hosted page and an <code
            class="font-mono text-[#00FFC8] text-base bg-[#00FFC8]/10 px-1.5"
            >embeddable widget</code
          >, or let a <code
            class="font-mono text-[#00FFC8] text-base bg-[#00FFC8]/10 px-1.5"
            >published npm CLI</code
          > turn git commits into release notes with an LLM. Built solo, end to
          end.
        </p>

        <div class="hero-enter flex flex-wrap gap-3" style="--delay: 0.65s">
          <a
            href="https://deploylog.dev"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-5 py-2.5 bg-transparent hover:bg-[#00FFC8]/[0.08] border border-[#00FFC8]/15 hover:border-[#00FFC8]/30 text-sm text-[#00FFC8]/55 hover:text-[#00FFC8]/75 transition-colors duration-150"
          >
            Visit deploylog.dev
            <svg
              class="arrow w-4 h-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
          <a
            href="https://www.npmjs.com/package/deploylog"
            target="_blank"
            rel="noopener noreferrer"
            class="github-link inline-flex items-center gap-2 px-5 py-2.5 bg-transparent hover:bg-cyan-400/[0.08] border border-cyan-400/15 hover:border-cyan-400/30 text-sm text-cyan-300/55 hover:text-cyan-300/75 transition-colors duration-150"
          >
            The CLI on npm
            <svg
              class="arrow w-4 h-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- ─── OVERVIEW MEDIA ────────────────────────────────────────────────── -->
    <div class="border-t border-[#1F1F1F]/50 py-12">
      <div class="max-w-4xl mx-auto px-6">
        <div
          class="reveal overflow-hidden border border-[#1F1F1F] bg-[#141414]"
        >
          <Image
            src={screenshot1}
            alt="DeployLog landing page: Ship the update. Skip the busywork."
            widths={[600, 1000, 1280]}
            sizes="(max-width: 900px) 100vw, 900px"
            loading="lazy"
          />
        </div>
        <p
          class="reveal text-[#666666] text-xs font-mono mt-3 text-center"
          style="--delay: 100ms"
        >
          deploylog.dev: the landing page also embeds DeployLog's own live widget
        </p>
      </div>
    </div>

    <!-- ─── ONE PLATFORM, FOUR SURFACES ──────────────────────────────────── -->
    <section id="surfaces" class="py-20 border-t border-[#1F1F1F]/50">
      <div class="max-w-5xl mx-auto px-6">
        <h2 class="reveal text-lg font-semibold text-[#F0F0F0] mb-10">
          One Platform, Four Publishing Surfaces
        </h2>
        <div
          class="reveal max-w-3xl space-y-5 text-[#888888] leading-relaxed"
          style="--delay: 100ms"
        >
          <p>
            A changelog is only useful where your users already are, so a single
            entry written once in the dashboard fans out to four surfaces: a
            hosted, SSR changelog page with per-entry canonical URLs and RSS/JSON
            feeds; an <strong class="text-[#F0F0F0] font-medium"
              >embeddable widget</strong
            > (vanilla TypeScript in a Shadow DOM, bundled with esbuild, no
            framework dependency) dropped in with one script tag; a <strong
              class="text-[#F0F0F0] font-medium">published npm CLI</strong
            >; and a GitHub Action that publishes straight from a Release.
          </p>
          <p>
            The two write-paths (dashboard and CLI/Action) hit the same API but
            never share an auth method. See below.
          </p>
        </div>
        <div class="reveal mt-8 max-w-3xl" style="--delay: 150ms">
          <pre><code class="language-html" set:text={`<!-- One script tag embeds the live changelog widget -->
<script
  src="https://cdn.deploylog.dev/widget.js"
  data-project="your-project-slug"
  defer
></script>`} /></pre>
        </div>
      </div>
    </section>

    <!-- ─── TWO AUTH MODELS ──────────────────────────────────────────────── -->
    <section id="auth" class="py-20 border-t border-[#1F1F1F]/50">
      <div class="max-w-5xl mx-auto px-6">
        <h2 class="reveal text-lg font-semibold text-[#F0F0F0] mb-10">
          Two Auth Models That Never Mix
        </h2>
        <div
          class="reveal max-w-3xl space-y-5 text-[#888888] leading-relaxed"
          style="--delay: 100ms"
        >
          <p>
            The dashboard authenticates with a Supabase cookie session and runs
            every query through the anon key, so Postgres <strong
              class="text-[#F0F0F0] font-medium">Row-Level Security</strong
            > does the access control. The CLI and integrations authenticate with
            a <code
              class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1"
              >dk_</code
            >-prefixed API key (stored only as a SHA-256 hash) and run through the
            service-role client, which bypasses RLS, so those endpoints must
            filter by <code
              class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1"
              >org_id</code
            > explicitly. The rule that keeps it safe: a given route handler uses
            exactly one of these, never both. CLI-only routes live under their own
            <code
              class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1"
              >/api/cli/*</code
            > namespace.
          </p>
        </div>
      </div>
    </section>

    <!-- ─── PLAN GATING + BILLING ────────────────────────────────────────── -->
    <section id="billing" class="py-20 border-t border-[#1F1F1F]/50">
      <div class="max-w-5xl mx-auto px-6">
        <h2 class="reveal text-lg font-semibold text-[#F0F0F0] mb-10">
          Capability-Based Plan Gating + Stripe Billing
        </h2>
        <div
          class="reveal max-w-3xl space-y-5 text-[#888888] leading-relaxed"
          style="--delay: 100ms"
        >
          <p>
            Every paid feature reads through one primitive (<code
              class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1"
              >can(org, capability)</code
            >) backed by a truth table keyed on the org's plan. Adding a new
            gated feature is one row in the table plus one call at the gate site,
            rather than scattering <code
              class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1"
              >plan === "pro"</code
            > checks across the codebase. Stripe is the source of truth for plan
            state: Checkout and the Customer Portal drive everything, and a
            webhook reconciles the org's plan on every subscription change, with a
            <code
              class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1"
              >stripe_events</code
            > table providing idempotency.
          </p>
        </div>
        <div class="reveal mt-8 max-w-3xl" style="--delay: 150ms">
          <pre><code class="language-typescript" set:text={`// src/lib/plan.ts: one source of truth for every feature gate
export function can(
  org: { plan: Plan } | null,
  capability: Capability,
): boolean {
  return CAPABILITIES[org?.plan ?? "free"].includes(capability);
}

// Gate site: projects API
if (!can(org, "unlimited_projects") && projectCount >= FREE_PROJECT_LIMIT) {
  return error("PLAN_LIMIT", "Upgrade to add more projects", 403);
}`} /></pre>
        </div>
      </div>
    </section>

    <!-- ─── AI RELEASE NOTES ─────────────────────────────────────────────── -->
    <section id="ai-notes" class="py-20 border-t border-[#1F1F1F]/50">
      <div class="max-w-5xl mx-auto px-6">
        <h2 class="reveal text-lg font-semibold text-[#F0F0F0] mb-10">
          AI Release Notes, Shared by CLI and Dashboard
        </h2>
        <div
          class="reveal max-w-3xl space-y-5 text-[#888888] leading-relaxed"
          style="--delay: 100ms"
        >
          <p>
            Both the dashboard editor and the CLI can turn raw commit messages
            into a clean, user-facing entry (title, type, Markdown body) with
            Claude Haiku. The two surfaces are thin auth shells over one shared
            service: the prompt, the JSON-validated output, the rate limit, and
            the free-tier monthly cap all live in a single module, so the two
            entry points can't drift apart. From the terminal it's one flag:
          </p>
        </div>
        <div class="reveal mt-8 max-w-3xl" style="--delay: 150ms">
          <pre><code class="language-bash" set:text={`# Generate release notes from git, rewritten by an LLM, and publish
deploylog push --from-git --ai-summarize`} /></pre>
        </div>
      </div>
    </section>

    <!-- ─── STACK ─────────────────────────────────────────────────────────── -->
    <section id="stack" class="py-20 border-t border-[#1F1F1F]/50">
      <div class="max-w-5xl mx-auto px-6">
        <h2 class="reveal text-lg font-semibold text-[#F0F0F0] mb-10">Stack</h2>
        <div
          class="reveal grid grid-cols-1 sm:grid-cols-2 gap-x-10 gap-y-3 max-w-3xl text-[#888888]"
          style="--delay: 100ms"
        >
          <p><span class="text-[#F0F0F0] font-medium">Frontend / API:</span> Next.js 16 (App Router, RSC), React 19, TypeScript (strict), Tailwind v4</p>
          <p><span class="text-[#F0F0F0] font-medium">Database / auth:</span> Supabase (PostgreSQL + RLS, GitHub OAuth)</p>
          <p><span class="text-[#F0F0F0] font-medium">Payments:</span> Stripe (Checkout, Portal, webhooks)</p>
          <p><span class="text-[#F0F0F0] font-medium">Email:</span> Resend + React Email templates</p>
          <p><span class="text-[#F0F0F0] font-medium">AI:</span> Anthropic Claude (Haiku) for release-note summarization</p>
          <p><span class="text-[#F0F0F0] font-medium">Editor / widget:</span> CodeMirror 6 · vanilla-TS Shadow-DOM widget (esbuild)</p>
          <p><span class="text-[#F0F0F0] font-medium">Infra:</span> Vercel · Cloudflare Pages (widget CDN) · Upstash · Sentry</p>
          <p><span class="text-[#F0F0F0] font-medium">Distribution:</span> npm CLI · GitHub Action on the Marketplace</p>
        </div>
      </div>
    </section>

    <!-- ─── SCREENSHOTS ───────────────────────────────────────────────────── -->
    <section
      id="screenshots"
      class="py-20 border-t border-[#1F1F1F]/50"
      data-screenshots={poster1.src}
    >
      <div class="max-w-5xl mx-auto px-6">
        <h2 class="reveal text-lg font-semibold text-[#F0F0F0] mb-10">
          Screenshots
        </h2>
        <div class="grid grid-cols-1 gap-4 max-w-3xl">
          <div class="reveal" style="--delay: 0ms">
            <div
              class="screenshot-wrap"
              role="button"
              tabindex="0"
              aria-label="Open screenshot 1"
              data-index="0"
            >
              <Image
                src={screenshot1}
                alt="DeployLog landing page hero and live widget"
                loading="lazy"
                widths={[400, 800, 1200]}
                sizes="(max-width: 640px) 100vw, 100vw"
              />
            </div>
            <p class="text-[#666666] text-xs font-mono mt-2">
              deploylog.dev: hero, CTAs, and the self-hosted live widget
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── RETROSPECTIVE ─────────────────────────────────────────────────── -->
    <section id="retrospective" class="py-20 border-t border-[#1F1F1F]/50">
      <div class="max-w-5xl mx-auto px-6">
        <h2 class="reveal text-lg font-semibold text-[#F0F0F0] mb-10">
          Retrospective
        </h2>
        <ul class="reveal space-y-4 max-w-3xl" style="--delay: 100ms">
          <li class="flex gap-3 text-[#888888] leading-relaxed">
            <span class="text-[#00FFC8] font-mono mt-0.5 shrink-0">//</span>
            <span>
              <strong class="text-[#F0F0F0] font-medium"
                >One capability table beats scattered plan checks.</strong
              >
              Routing every gate through <code
                class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1"
                >can()</code
              > meant adding the Pro tier late in development touched one file, not
              twenty.
            </span>
          </li>
          <li class="flex gap-3 text-[#888888] leading-relaxed">
            <span class="text-[#00FFC8] font-mono mt-0.5 shrink-0">//</span>
            <span>
              <strong class="text-[#F0F0F0] font-medium"
                >Sharing one service across CLI and dashboard prevents drift.</strong
              >
              The AI-summarize logic lives once; the two surfaces are just auth +
              transport. The same shape would have saved time if applied to more
              dual-surface endpoints from the start.
            </span>
          </li>
          <li class="flex gap-3 text-[#888888] leading-relaxed">
            <span class="text-[#00FFC8] font-mono mt-0.5 shrink-0">//</span>
            <span>
              <strong class="text-[#F0F0F0] font-medium"
                >The widget being framework-free was the right call.</strong
              >
              A Shadow-DOM vanilla-TS bundle drops into any site without pulling in
              React or clashing with host styles, the constraint that made it
              small also made it universal.
            </span>
          </li>
        </ul>
      </div>
    </section>
  </main>

  <!-- ─── FOOTER ────────────────────────────────────────────────────────── -->
  <footer class="border-t border-[#1F1F1F]/50 py-8">
    <div
      class="max-w-5xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-4"
    >
      <p class="text-[#888888] text-sm">© 2026 Marko Stankovic</p>
      <div class="flex items-center gap-6 text-sm">
        <a
          href="/projects/tictactoe"
          class="nav-link text-[#888888] hover:text-[#F0F0F0] transition-colors duration-150"
        >
          Tic-Tac-Toe
        </a>
      </div>
      <p class="text-[#666666] text-xs font-mono">
        Technical Artist · Gameplay Programmer · Serbia
      </p>
    </div>
  </footer>

  <!-- ─── LIGHTBOX ──────────────────────────────────────────────────────── -->
  <div
    id="lightbox"
    role="dialog"
    aria-modal="true"
    aria-label="Screenshot viewer"
    class="fixed inset-0 z-[200] items-center justify-center"
  >
    <div id="lightbox-backdrop" class="absolute inset-0 bg-[#0D0D0D]/95"></div>
    <div id="lightbox-content" class="relative z-10 flex items-center gap-3 px-4">
      <button id="lightbox-prev" class="lb-btn" aria-label="Previous screenshot">
        <svg
          width="20"
          height="20"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24"
          aria-hidden="true"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M15 19l-7-7 7-7"></path></svg
        >
      </button>
      <img id="lightbox-img" src="data:," alt="Project screenshot" />
      <button id="lightbox-next" class="lb-btn" aria-label="Next screenshot">
        <svg
          width="20"
          height="20"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24"
          aria-hidden="true"
          ><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"
          ></path></svg
        >
      </button>
    </div>
    <button id="lightbox-close" class="lb-btn z-10" aria-label="Close lightbox">
      <svg
        width="20"
        height="20"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        viewBox="0 0 24 24"
        aria-hidden="true"
        ><path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M6 18L18 6M6 6l12 12"></path></svg
      >
    </button>
  </div>

  <script>
    // @ts-ignore
    if (typeof hljs !== "undefined") hljs.highlightAll();

    document.querySelectorAll("pre").forEach((pre) => {
      const wrap = document.createElement("div");
      wrap.className = "pre-wrap";
      pre.parentNode?.insertBefore(wrap, pre);
      wrap.appendChild(pre);

      const btn = document.createElement("button");
      btn.className = "copy-btn";
      btn.textContent = "copy";
      btn.setAttribute("aria-label", "Copy code");
      wrap.appendChild(btn);

      btn.addEventListener("click", () => {
        const code = pre.querySelector("code");
        const text = code?.textContent ?? "";
        navigator.clipboard.writeText(text).then(() => {
          btn.textContent = "copied!";
          btn.classList.add("copied");
          setTimeout(() => {
            btn.textContent = "copy";
            btn.classList.remove("copied");
          }, 2000);
        });
      });
    });

    const prefersReduced = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    const revealEls = document.querySelectorAll(".reveal");
    if (!prefersReduced) {
      const obs = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add("visible");
              obs.unobserve(e.target);
            }
          });
        },
        { threshold: 0.1 },
      );
      revealEls.forEach((el) => obs.observe(el));
    } else {
      revealEls.forEach((el) => el.classList.add("visible"));
    }

    const lightbox = document.getElementById("lightbox");
    const lbImg = document.getElementById("lightbox-img");
    const lbPrev = document.getElementById("lightbox-prev");
    const lbNext = document.getElementById("lightbox-next");
    const lbClose = document.getElementById("lightbox-close");
    const lbBackdrop = document.getElementById("lightbox-backdrop");
    const section = document.getElementById("screenshots");
    const lbScreenshots = (section?.dataset.screenshots ?? "")
      .split(",")
      .map((s) => s.trim())
      .filter(Boolean);
    let lbIndex = 0;
    let lbPrevFocus = null;

    function lbShow(index) {
      lbIndex = index;
      lbPrevFocus = document.activeElement;
      lbUpdate();
      lightbox.style.display = "flex";
      requestAnimationFrame(() => {
        lightbox.classList.add("lb-open");
        document.body.style.overflow = "hidden";
        lbClose.focus();
      });
    }
    function lbHide() {
      lightbox.classList.remove("lb-open");
      lightbox.addEventListener(
        "transitionend",
        () => {
          lightbox.style.display = "none";
          document.body.style.overflow = "";
          lbPrevFocus?.focus();
        },
        { once: true },
      );
    }
    function lbUpdate() {
      lbImg.src = lbScreenshots[lbIndex];
      lbImg.alt = `Screenshot ${lbIndex + 1} of ${lbScreenshots.length}`;
      lbPrev.disabled = lbIndex === 0;
      lbNext.disabled = lbIndex === lbScreenshots.length - 1;
    }

    document.querySelectorAll(".screenshot-wrap").forEach((wrap) => {
      const open = () => lbShow(parseInt(wrap.dataset.index ?? "0", 10));
      wrap.addEventListener("click", open);
      wrap.addEventListener("keydown", (e) => {
        if (e.key === "Enter" || e.key === " ") {
          e.preventDefault();
          open();
        }
      });
    });
    lbClose.addEventListener("click", lbHide);
    lbBackdrop.addEventListener("click", lbHide);
    lbPrev.addEventListener("click", () => {
      if (lbIndex > 0) {
        lbIndex--;
        lbUpdate();
      }
    });
    lbNext.addEventListener("click", () => {
      if (lbIndex < lbScreenshots.length - 1) {
        lbIndex++;
        lbUpdate();
      }
    });
    lightbox.addEventListener("keydown", (e) => {
      if (e.key === "Escape") lbHide();
      else if (e.key === "ArrowLeft" && lbIndex > 0) {
        lbIndex--;
        lbUpdate();
      } else if (e.key === "ArrowRight" && lbIndex < lbScreenshots.length - 1) {
        lbIndex++;
        lbUpdate();
      }
    });
  </script>
</BaseLayout>
