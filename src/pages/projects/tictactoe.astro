---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteNav from "../../components/SiteNav.astro";
import { Image } from "astro:assets";
import shotNeon from "../../assets/screenshots/tictactoe-neon.png";
import shotWood from "../../assets/screenshots/tictactoe-wood.png";
import shotJungle from "../../assets/screenshots/tictactoe-jungle.png";
import shotCandy from "../../assets/screenshots/tictactoe-candy.png";
import shotThemes from "../../assets/screenshots/tictactoe-themes.png";
import shotMobileNeon from "../../assets/screenshots/tictactoe-mobile-neon.jpg";
import shotMobileWood from "../../assets/screenshots/tictactoe-mobile-wood.jpg";

const pageTitle = "Tic-Tac-Toe | Marko Stankovic";
const pageDescription =
  "Local-multiplayer Tic-Tac-Toe in Unity 6 with a data-driven theme system: one ScriptableObject per theme, five segregated interfaces, and a zero-code path to adding a new theme. Shipped and playable on itch.";
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  codeHighlighting={true}
>
  <Fragment slot="head">
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "Tic-Tac-Toe",
        "description": "Local-multiplayer Tic-Tac-Toe in Unity 6 with a data-driven, interface-segregated theme system. Shipped on itch.",
        "applicationCategory": "Game",
        "operatingSystem": "Web Browser",
        "author": {
          "@type": "Person",
          "name": "Marko Stankovic",
          "url": "https://markostankovic.org"
        },
        "url": "https://markostankovic.org/projects/tictactoe"
      }
    </script>
  </Fragment>
  <!-- ─── NAV ─────────────────────────────────────────────────────────── -->
  <SiteNav active="work" />

  <main>
    <!-- ─── HERO ──────────────────────────────────────────────────────────── -->
    <div class="relative pt-14">
      <div class="relative max-w-5xl mx-auto px-6 py-20">
        <a
          href="/#work"
          class="hero-enter inline-block text-[#666666] hover:text-[#00FFC8] font-mono text-xs mb-6 tracking-wide transition-colors duration-150"
          style="--delay: 0.05s"
        >
          back
        </a>

        <div
          class="hero-enter flex flex-wrap gap-2 mb-6"
          style="--delay: 0.15s"
        >
          <span
            class="text-xs font-mono bg-[#00FFC8]/[0.08] text-[#00FFC8]/75 border border-[#00FFC8]/20 px-3 py-1"
          >
            Shipped · Live on itch
          </span>
          <span
            class="text-xs font-mono bg-cyan-400/[0.08] text-cyan-300/75 border border-cyan-400/20 px-3 py-1"
          >
            Unity 6 · C#
          </span>
        </div>

        <h1
          class="hero-enter font-mono font-bold text-[#F0F0F0] mb-5"
          style="font-size: clamp(2.5rem, 6vw, 4.5rem); line-height: 1.05; letter-spacing: -0.02em; --delay: 0.3s"
        >
          Tic-Tac-Toe
        </h1>

        <p
          class="hero-enter text-[#888888] text-lg max-w-2xl leading-relaxed mb-8"
          style="--delay: 0.5s"
        >
          Add a whole new theme in one <code
            class="font-mono text-[#00FFC8] text-base bg-[#00FFC8]/10 px-1.5"
            >ScriptableObject</code
          > and zero new code. A shipped, local-multiplayer Tic-Tac-Toe whose
          real story is its theming: six themes repaint the board, UI, HUD, and
          audio from a single menu tap, split across five segregated interfaces,
          so every system depends only on the data it actually paints.
        </p>

        <div class="hero-enter flex flex-wrap gap-3" style="--delay: 0.65s">
          <a
            href="https://marko-builds.itch.io/tictactoe"
            target="_blank"
            rel="noopener noreferrer"
            class="github-link inline-flex items-center gap-2 px-5 py-2.5 bg-transparent hover:bg-[#00FFC8]/[0.08] border border-[#00FFC8]/15 hover:border-[#00FFC8]/30 text-sm text-[#00FFC8]/55 hover:text-[#00FFC8]/75 transition-colors duration-150"
          >
            <svg
              class="w-4 h-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"
              ></path>
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            Play on itch
            <svg
              class="arrow w-4 h-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
          <a
            href="/devlog/tictactoe-theme-system"
            class="inline-flex items-center gap-2 px-5 py-2.5 bg-transparent hover:bg-[#00FFC8]/[0.08] border border-[#00FFC8]/15 hover:border-[#00FFC8]/30 text-sm text-[#00FFC8]/55 hover:text-[#00FFC8]/75 transition-colors duration-150"
          >
            <svg
              class="w-4 h-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
              ></path>
            </svg>
            Read the devlog
            <svg
              class="arrow w-4 h-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- ─── SCREENSHOTS ───────────────────────────────────────────────────── -->
    <section
      id="screenshots"
      class="py-20 border-t border-[#1F1F1F]/50"
      data-screenshots={`${shotNeon.src},${shotWood.src},${shotJungle.src},${shotCandy.src},${shotThemes.src},${shotMobileNeon.src},${shotMobileWood.src}`}
    >
      <div class="max-w-5xl mx-auto px-6">
        <h2 class="reveal text-lg font-semibold text-[#F0F0F0] mb-3">
          Themes
        </h2>
        <p
          class="reveal max-w-3xl text-[#888888] leading-relaxed mb-10"
          style="--delay: 100ms"
        >
          Same board, four <code
            class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1"
            >ThemeSO</code
          > assets. One menu tap repaints the grid, the marks, the HUD, the background,
          and the music. No code path changes.
        </p>

        <!-- Desktop theme boards (16:10) -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="reveal" style="--delay: 0ms">
            <div
              class="screenshot-wrap"
              role="button"
              tabindex="0"
              aria-label="Open Neon theme screenshot"
              data-index="0"
            >
              <Image
                src={shotNeon}
                alt="Tic-Tac-Toe, Neon theme: neon-grid board, pink X and cyan O marks"
                loading="lazy"
                widths={[400, 800, 1200]}
                sizes="(max-width: 640px) 100vw, 50vw"
              />
            </div>
            <p class="text-[#666666] text-xs font-mono mt-2">Neon</p>
          </div>

          <div class="reveal" style="--delay: 80ms">
            <div
              class="screenshot-wrap"
              role="button"
              tabindex="0"
              aria-label="Open Wood theme screenshot"
              data-index="1"
            >
              <Image
                src={shotWood}
                alt="Tic-Tac-Toe, Wood theme: carved wooden board with raised X and O pieces"
                loading="lazy"
                widths={[400, 800, 1200]}
                sizes="(max-width: 640px) 100vw, 50vw"
              />
            </div>
            <p class="text-[#666666] text-xs font-mono mt-2">Wood</p>
          </div>

          <div class="reveal" style="--delay: 0ms">
            <div
              class="screenshot-wrap"
              role="button"
              tabindex="0"
              aria-label="Open Jungle theme screenshot"
              data-index="2"
            >
              <Image
                src={shotJungle}
                alt="Tic-Tac-Toe, Jungle theme: bamboo-framed board on a leafy background"
                loading="lazy"
                widths={[400, 800, 1200]}
                sizes="(max-width: 640px) 100vw, 50vw"
              />
            </div>
            <p class="text-[#666666] text-xs font-mono mt-2">Jungle</p>
          </div>

          <div class="reveal" style="--delay: 80ms">
            <div
              class="screenshot-wrap"
              role="button"
              tabindex="0"
              aria-label="Open Candy theme screenshot"
              data-index="3"
            >
              <Image
                src={shotCandy}
                alt="Tic-Tac-Toe, Candy theme: pastel marshmallow tiles with green X and blue O"
                loading="lazy"
                widths={[400, 800, 1200]}
                sizes="(max-width: 640px) 100vw, 50vw"
              />
            </div>
            <p class="text-[#666666] text-xs font-mono mt-2">Candy</p>
          </div>
        </div>

        <!-- The selection screen: the feature itself -->
        <div class="reveal mt-4" style="--delay: 100ms">
          <div
            class="screenshot-wrap"
            role="button"
            tabindex="0"
            aria-label="Open theme selection screenshot"
            data-index="4"
          >
            <Image
              src={shotThemes}
              alt="Tic-Tac-Toe theme selection popup listing all six themes: Classic, Neon, Nature, Candy, Wood, Jungle"
              loading="lazy"
              widths={[640, 1280]}
              sizes="100vw"
            />
          </div>
          <p class="text-[#666666] text-xs font-mono mt-2">
            The selection popup. Each entry is one ThemeSO registered with the manager.
          </p>
        </div>

        <!-- Mobile (portrait) -->
        <h3 class="reveal font-mono text-sm text-[#888888] mt-14 mb-4">
          On mobile (portrait)
        </h3>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
          <div class="reveal" style="--delay: 0ms">
            <div
              class="screenshot-wrap"
              role="button"
              tabindex="0"
              aria-label="Open Neon theme on mobile"
              data-index="5"
            >
              <Image
                src={shotMobileNeon}
                alt="Tic-Tac-Toe on a phone, Neon theme in portrait orientation"
                loading="lazy"
                widths={[270, 540]}
                sizes="(max-width: 640px) 50vw, 25vw"
              />
            </div>
            <p class="text-[#666666] text-xs font-mono mt-2">Neon</p>
          </div>

          <div class="reveal" style="--delay: 80ms">
            <div
              class="screenshot-wrap"
              role="button"
              tabindex="0"
              aria-label="Open Wood theme on mobile"
              data-index="6"
            >
              <Image
                src={shotMobileWood}
                alt="Tic-Tac-Toe on a phone, Wood theme in portrait orientation"
                loading="lazy"
                widths={[270, 540]}
                sizes="(max-width: 640px) 50vw, 25vw"
              />
            </div>
            <p class="text-[#666666] text-xs font-mono mt-2">Wood</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── OVERVIEW ──────────────────────────────────────────────────────── -->
    <section id="overview" class="py-20 border-t border-[#1F1F1F]/50">
      <div class="max-w-5xl mx-auto px-6">
        <h2 class="reveal text-lg font-semibold text-[#F0F0F0] mb-10">
          Overview
        </h2>
        <div
          class="reveal max-w-3xl space-y-5 text-[#888888] leading-relaxed"
          style="--delay: 100ms"
        >
          <p>
            Local two-player Tic-Tac-Toe built in Unity 6: win detection with an
            animated strike line, a match timer and per-player move counts,
            statistics that persist across sessions, saved audio settings, and
            both portrait and landscape support. Small on the surface. The part
            worth writing about is how a single menu choice repaints the entire
            game.
          </p>
        </div>
      </div>
    </section>

    <!-- ─── ARCHITECTURE ──────────────────────────────────────────────────── -->
    <section id="architecture" class="py-20 border-t border-[#1F1F1F]/50">
      <div class="max-w-5xl mx-auto px-6">
        <h2 class="reveal text-lg font-semibold text-[#F0F0F0] mb-10">
          Architecture: Theming as Data, Not Code
        </h2>

        <div class="space-y-14">
          <!-- Card 1: One ScriptableObject per theme + ISP -->
          <div class="reveal" style="--delay: 0ms">
            <div class="border border-[#1F1F1F] p-8">
              <h3 class="font-mono font-semibold text-[#F0F0F0] text-lg mb-3">
                One ScriptableObject Per Theme, Five Segregated Interfaces
              </h3>
              <p class="text-[#888888] leading-relaxed mb-6 max-w-3xl">
                A theme is a <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1"
                  >ThemeSO</code
                > asset. Adding one means creating an asset and filling its
                fields. No code, no recompile, and a designer can do it. The asset implements
                five interfaces instead of exposing one fat type, so each system
                depends only on the surface it paints: the audio system on <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1"
                  >IThemeAudio</code
                >, the board on <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1"
                  >IThemeBoard</code
                >, the selection popup on <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1"
                  >ITheme</code
                > (id and name only). A change to the board surface cannot ripple
                into audio code. Each sprite slot has a color fallback, so a theme
                can ship flat-color first and gain bespoke art later, per surface,
                without touching code.
              </p>
              <pre><code class="language-csharp" set:text={`// Data/ThemeSO.cs: one asset per theme, implements all five surfaces
[CreateAssetMenu(fileName = "Theme_Classic", menuName = "TicTacToe/Theme")]
public class ThemeSO : ScriptableObject,
    ITheme, IThemeBoard, IThemeUI, IThemeHUD, IThemeAudio
{
    // serialized fields for every surface; sprite slots fall back to a Color
}

// Interfaces/ITheme.cs: the narrowest surface (identity only)
public interface ITheme
{
    string ThemeId { get; }      // stable id persisted in GameSettings
    string DisplayName { get; }  // shown in the theme-selection popup
}

// Segregated surfaces a consumer can depend on instead of the whole theme:
//   IThemeBoard  - board background, cells, marks, player tints
//   IThemeUI     - scene background, buttons, popups
//   IThemeHUD    - HUD text, settings indicator, strike color
//   IThemeAudio  - background clip`} /></pre>
            </div>
          </div>

          <!-- Card 2: Decoupled repaint via narrow event + appliers -->
          <div class="reveal" style="--delay: 50ms">
            <div class="border border-[#1F1F1F] p-8">
              <h3 class="font-mono font-semibold text-[#F0F0F0] text-lg mb-3">
                Swapping Themes Without Coupling Anything
              </h3>
              <p class="text-[#888888] leading-relaxed mb-6 max-w-3xl">
                <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1"
                  >ThemeManager</code
                > is a persistent singleton. On a change it persists the choice through
                <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1"
                  >SaveManager</code
                > and fires one event carrying the identity view only, a deliberately
                narrow payload. Painters that need richer data read the <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1"
                  >ActiveTheme...</code
                > property for their own surface. Each painter is a small applier that
                subscribes on enable and re-applies on every change, so a mid-match
                theme swap repaints the whole scene with no special-case code. Two
                safeguards: a stale theme id falls back to the first theme (an old save
                never loads blank), and ids live in one <code
                  class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1"
                  >ThemeIds</code
                > class so a rename is a compile error, not a silent fallback.
              </p>
              <pre><code class="language-csharp" set:text={`// Core/ThemeManager.cs: narrow broadcast, per-surface accessors
public static event Action<ITheme> OnThemeChanged;

public IThemeBoard ActiveThemeBoard { get; private set; }
public IThemeUI    ActiveThemeUI    { get; private set; }
public IThemeHUD   ActiveThemeHUD   { get; private set; }
public IThemeAudio ActiveThemeAudio { get; private set; }

public void ApplyTheme(string themeId)
{
    ThemeSO resolved = FindThemeById(themeId) ?? _availableThemes[0]; // stale-id safe
    if (ActiveTheme != null && ActiveTheme.ThemeId == resolved.ThemeId) return;

    BindActiveTheme(resolved);                       // sets all five surfaces
    SaveManager.Instance?.UpdateSelectedTheme(resolved.ThemeId);
    OnThemeChanged?.Invoke(ActiveTheme);             // identity view only
}

// UI/Shared/HUDThemeApplier.cs: one painter, depends on IThemeHUD only
private void HandleThemeChanged(ITheme _)
{
    IThemeHUD theme = ThemeManager.Instance.ActiveThemeHUD;
    foreach (TMP_Text label in _hudTexts) label.color = theme.HUDTextColor;
    _settingsIndicator.color = theme.SettingsIndicatorColor;
}`} /></pre>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── RETROSPECTIVE ─────────────────────────────────────────────────── -->
    <section id="retrospective" class="py-20 border-t border-[#1F1F1F]/50">
      <div class="max-w-5xl mx-auto px-6">
        <h2 class="reveal text-lg font-semibold text-[#F0F0F0] mb-10">
          Retrospective
        </h2>

        <ul class="reveal space-y-4 max-w-3xl" style="--delay: 100ms">
          <li class="flex gap-3 text-[#888888] leading-relaxed">
            <span class="text-[#00FFC8] font-mono mt-0.5 shrink-0">&bull;</span>
            <span>
              <strong class="text-[#F0F0F0] font-medium"
                >Interface segregation earned its place at more than two themes.</strong
              >
              The five-way split looks like overkill for a Tic-Tac-Toe at first
              glance. It paid off the moment more than one system painted itself:
              every surface stayed independent, and "add a theme" stayed a
              five-minute asset job for the life of the project.
            </span>
          </li>
          <li class="flex gap-3 text-[#888888] leading-relaxed">
            <span class="text-[#00FFC8] font-mono mt-0.5 shrink-0">&bull;</span>
            <span>
              <strong class="text-[#F0F0F0] font-medium"
                >The sprite-or-color fallback unblocked the art pipeline.</strong
              >
              Shipping flat-color themes first and adding sprites later, per
              surface, meant the architecture and the art never blocked each
              other.
            </span>
          </li>
          <li class="flex gap-3 text-[#888888] leading-relaxed">
            <span class="text-[#00FFC8] font-mono mt-0.5 shrink-0">&bull;</span>
            <span>
              <strong class="text-[#F0F0F0] font-medium"
                >A narrow event payload kept the broadcast honest.</strong
              >
              Carrying only <code
                class="font-mono text-[#00FFC8] text-sm bg-[#00FFC8]/10 px-1"
                >ITheme</code
              > in the change event, and letting listeners pull the surface they
              need, stopped the broadcast from becoming a dumping ground as
              surfaces grew.
            </span>
          </li>
        </ul>
      </div>
    </section>
  </main>

  <!-- ─── FOOTER ────────────────────────────────────────────────────────── -->
  <footer class="border-t border-[#1F1F1F]/50 py-8">
    <div
      class="max-w-5xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-4"
    >
      <p class="text-[#888888] text-sm">© 2026 Marko Stankovic</p>
      <div class="flex items-center gap-6 text-sm">
        <a
          href="/devlog/tictactoe-theme-system"
          class="nav-link text-[#888888] hover:text-[#F0F0F0] transition-colors duration-150"
        >
          Read the devlog
        </a>
        <a
          href="/projects/hide-and-seek"
          class="nav-link text-[#888888] hover:text-[#F0F0F0] transition-colors duration-150"
        >
          Hide and Seek
        </a>
      </div>
      <p class="text-[#666666] text-xs font-mono">
        Technical Artist · Gameplay Programmer · Serbia
      </p>
    </div>
  </footer>

  <!-- ─── LIGHTBOX ──────────────────────────────────────────────────────── -->
  <div
    id="lightbox"
    role="dialog"
    aria-modal="true"
    aria-label="Screenshot viewer"
    class="fixed inset-0 z-[200] items-center justify-center"
  >
    <div id="lightbox-backdrop" class="absolute inset-0 bg-[#0D0D0D]/95"></div>
    <div
      id="lightbox-content"
      class="relative z-10 flex items-center gap-3 px-4"
    >
      <button id="lightbox-prev" class="lb-btn" aria-label="Previous screenshot">
        <svg
          width="20"
          height="20"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24"
          aria-hidden="true"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M15 19l-7-7 7-7"></path></svg
        >
      </button>
      <img id="lightbox-img" src="data:," alt="Project screenshot" />
      <button id="lightbox-next" class="lb-btn" aria-label="Next screenshot">
        <svg
          width="20"
          height="20"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24"
          aria-hidden="true"
          ><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"
          ></path></svg
        >
      </button>
    </div>
    <button id="lightbox-close" class="lb-btn z-10" aria-label="Close lightbox">
      <svg
        width="20"
        height="20"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        viewBox="0 0 24 24"
        aria-hidden="true"
        ><path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M6 18L18 6M6 6l12 12"></path></svg
      >
    </button>
  </div>

  <script>
    // Syntax highlighting
    // @ts-ignore
    if (typeof hljs !== "undefined") hljs.highlightAll();

    // Wrap pre blocks and add a copy button
    document.querySelectorAll("pre").forEach((pre) => {
      const wrap = document.createElement("div");
      wrap.className = "pre-wrap";
      pre.parentNode?.insertBefore(wrap, pre);
      wrap.appendChild(pre);

      const btn = document.createElement("button");
      btn.className = "copy-btn";
      btn.textContent = "copy";
      btn.setAttribute("aria-label", "Copy code");
      wrap.appendChild(btn);

      btn.addEventListener("click", () => {
        const code = pre.querySelector("code");
        const text = code?.textContent ?? "";
        navigator.clipboard.writeText(text).then(() => {
          btn.textContent = "copied!";
          btn.classList.add("copied");
          setTimeout(() => {
            btn.textContent = "copy";
            btn.classList.remove("copied");
          }, 2000);
        });
      });
    });

    // Reveal-on-scroll
    const prefersReduced = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    const revealEls = document.querySelectorAll(".reveal");
    if (!prefersReduced) {
      const obs = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add("visible");
              obs.unobserve(e.target);
            }
          });
        },
        { threshold: 0.1 },
      );
      revealEls.forEach((el) => obs.observe(el));
    } else {
      revealEls.forEach((el) => el.classList.add("visible"));
    }

    // Lightbox
    const lightbox = document.getElementById("lightbox");
    const lbImg = document.getElementById("lightbox-img");
    const lbPrev = document.getElementById("lightbox-prev");
    const lbNext = document.getElementById("lightbox-next");
    const lbClose = document.getElementById("lightbox-close");
    const lbBackdrop = document.getElementById("lightbox-backdrop");
    const section = document.getElementById("screenshots");
    const lbScreenshots = (section?.dataset.screenshots ?? "")
      .split(",")
      .map((s) => s.trim())
      .filter(Boolean);
    let lbIndex = 0;
    let lbPrevFocus = null;

    function lbShow(index) {
      lbIndex = index;
      lbPrevFocus = document.activeElement;
      lbUpdate();
      lightbox.style.display = "flex";
      requestAnimationFrame(() => {
        lightbox.classList.add("lb-open");
        document.body.style.overflow = "hidden";
        lbClose.focus();
      });
    }
    function lbHide() {
      lightbox.classList.remove("lb-open");
      lightbox.addEventListener(
        "transitionend",
        () => {
          lightbox.style.display = "none";
          document.body.style.overflow = "";
          lbPrevFocus?.focus();
        },
        { once: true },
      );
    }
    function lbUpdate() {
      lbImg.src = lbScreenshots[lbIndex];
      lbImg.alt = `Screenshot ${lbIndex + 1} of ${lbScreenshots.length}`;
      lbPrev.disabled = lbIndex === 0;
      lbNext.disabled = lbIndex === lbScreenshots.length - 1;
    }

    document.querySelectorAll(".screenshot-wrap").forEach((wrap) => {
      const open = () => lbShow(parseInt(wrap.dataset.index ?? "0", 10));
      wrap.addEventListener("click", open);
      wrap.addEventListener("keydown", (e) => {
        if (e.key === "Enter" || e.key === " ") {
          e.preventDefault();
          open();
        }
      });
    });
    lbClose.addEventListener("click", lbHide);
    lbBackdrop.addEventListener("click", lbHide);
    lbPrev.addEventListener("click", () => {
      if (lbIndex > 0) {
        lbIndex--;
        lbUpdate();
      }
    });
    lbNext.addEventListener("click", () => {
      if (lbIndex < lbScreenshots.length - 1) {
        lbIndex++;
        lbUpdate();
      }
    });
    lightbox.addEventListener("keydown", (e) => {
      if (e.key === "Escape") lbHide();
      else if (e.key === "ArrowLeft" && lbIndex > 0) {
        lbIndex--;
        lbUpdate();
      } else if (e.key === "ArrowRight" && lbIndex < lbScreenshots.length - 1) {
        lbIndex++;
        lbUpdate();
      }
    });
  </script>
</BaseLayout>
