---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import BlogCard from "../components/BlogCard.astro";
import Avatar from "../components/Avatar.astro";
import { getImage } from "astro:assets";
import endlessRunner1Raw from "../assets/screenshots/endless-runner-1.png";
import endlessRunner2Raw from "../assets/screenshots/endless-runner-2.png";
import deploylog1Raw from "../assets/screenshots/deploylog-1.png";
const endlessRunner1 = await getImage({
  src: endlessRunner1Raw,
  format: "webp",
  width: 800,
});
const endlessRunner2 = await getImage({
  src: endlessRunner2Raw,
  format: "webp",
  width: 800,
});
const deploylog1 = await getImage({
  src: deploylog1Raw,
  format: "webp",
  width: 800,
});

const recentPosts = (await getCollection("blog"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 2)
  .map((post) => {
    const words = (post.body ?? "").split(/\s+/).filter(Boolean).length;
    return { ...post, readingTime: Math.max(1, Math.ceil(words / 200)) };
  });

const pageTitle = "Marko Stankovic — Generalist Technical Artist & Gameplay Programmer";
const pageDescription =
  "Generalist Technical Artist and gameplay programmer in Unity and Unreal Engine 5. Gameplay systems, AI state machines, editor tooling, and pipeline automation. C# and C++. Based in Serbia, open to remote / EU.";

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Marko Stankovic",
  url: "https://markostankovic.org",
  jobTitle: "Generalist Technical Artist",
  sameAs: [
    "https://github.com/Idzuo32",
    "https://www.linkedin.com/in/markostankovic-gamedev/",
  ],
};
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <Fragment slot="head">
    <script
      type="application/ld+json"
      set:html={JSON.stringify(personSchema)}
    />
  </Fragment>
  <style>
    /* ── Thumbnail hover scale ── */
    .thumb-wrap {
      overflow: hidden;
    }
    .thumb-wrap video,
    .thumb-wrap img {
      transition: transform 0.3s ease;
      will-change: transform;
    }
    .project-card:hover .thumb-wrap video,
    .project-card:hover .thumb-wrap img {
      transform: scale(1.03);
    }

    /* ── Lightbox ── */
    #lightbox {
      display: none;
      opacity: 0;
      transition: opacity 0.2s ease;
    }
    #lightbox.lb-open {
      display: flex;
      opacity: 1;
    }
    #lightbox-content {
      transform: scale(0.95);
      transition: transform 0.2s ease;
    }
    #lightbox.lb-open #lightbox-content {
      transform: scale(1);
    }
    #lightbox-img {
      max-width: 90vw;
      max-height: 90vh;
      object-fit: contain;
      border-radius: 0.5rem;
      display: block;
    }
    .lb-btn {
      width: 2.75rem;
      height: 2.75rem;
      border-radius: 9999px;
      background: rgba(31, 31, 31, 0.8);
      border: 1px solid #2a2a2a;
      color: #f0f0f0;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      flex-shrink: 0;
      transition:
        background 0.15s ease,
        border-color 0.15s ease;
    }
    .lb-btn:hover {
      background: rgba(50, 50, 50, 0.9);
      border-color: #888;
    }
    .lb-btn:disabled {
      opacity: 0.3;
      cursor: default;
    }
    #lightbox-close {
      position: absolute;
      top: 1rem;
      right: 1rem;
    }
  </style>

  <!-- ─── NAV ──────────────────────────────────────────────────────────── -->
  <header
    class="fixed top-0 inset-x-0 z-50 border-b border-[#1F1F1F]/60 bg-[#0D0D0D]/80 backdrop-blur-md"
  >
    <nav class="max-w-5xl mx-auto px-6 h-14 flex items-center justify-between">
      <a
        href="#hero"
        class="font-bold font-mono tracking-tight text-[#F0F0F0] text-lg">MS</a
      >

      <!-- Desktop nav -->
      <ul class="hidden sm:flex gap-6 text-sm text-[#888888]">
        <li>
          <a
            href="#skills"
            class="nav-link hover:text-[#F0F0F0] transition-colors duration-150"
            >Skills</a
          >
        </li>
        <li>
          <a
            href="#projects"
            class="nav-link hover:text-[#F0F0F0] transition-colors duration-150"
            >Projects</a
          >
        </li>
        <li>
          <a
            href="/devlog"
            class="nav-link hover:text-[#F0F0F0] transition-colors duration-150"
            >Devlog</a
          >
        </li>
        <li>
          <a
            href="#contact"
            class="nav-link hover:text-[#F0F0F0] transition-colors duration-150"
            >Let's Build</a
          >
        </li>
      </ul>

      <!-- Hamburger button (mobile only) -->
      <button
        id="menu-btn"
        class="sm:hidden w-11 h-11 flex items-center justify-center text-[#888888] hover:text-[#F0F0F0] transition-colors duration-150"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg
          id="icon-menu"
          class="w-5 h-5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
        <svg
          id="icon-close"
          class="w-5 h-5 hidden"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </nav>

    <!-- Mobile nav dropdown -->
    <div id="mobile-nav" aria-hidden="true">
      <div class="max-w-5xl mx-auto px-6 py-2 flex flex-col">
        <a
          href="#skills"
          tabindex="-1"
          class="mobile-nav-link py-3 text-sm text-[#888888] hover:text-[#F0F0F0] border-b border-[#1F1F1F] transition-colors duration-150 min-h-[44px] flex items-center"
          >Skills</a
        >
        <a
          href="#projects"
          tabindex="-1"
          class="mobile-nav-link py-3 text-sm text-[#888888] hover:text-[#F0F0F0] border-b border-[#1F1F1F] transition-colors duration-150 min-h-[44px] flex items-center"
          >Projects</a
        >
        <a
          href="/devlog"
          tabindex="-1"
          class="mobile-nav-link py-3 text-sm text-[#888888] hover:text-[#F0F0F0] border-b border-[#1F1F1F] transition-colors duration-150 min-h-[44px] flex items-center"
          >Devlog</a
        >
        <a
          href="#contact"
          tabindex="-1"
          class="mobile-nav-link py-3 text-sm text-[#888888] hover:text-[#F0F0F0] transition-colors duration-150 min-h-[44px] flex items-center"
          >Let's Build</a
        >
      </div>
    </div>
  </header>

  <main>
    <!-- ─── HERO ──────────────────────────────────────────────────────────── -->
    <section id="hero" class="relative min-h-screen flex items-center pt-14">
      <!-- Decorative background glows -->
      <div
        class="absolute inset-0 overflow-hidden pointer-events-none"
        aria-hidden="true"
      >
        <div
          class="absolute top-1/4 left-1/3 w-[700px] h-[700px] bg-[#00FFC8]/5 rounded-full blur-3xl"
        >
        </div>
        <div
          class="absolute bottom-1/4 right-1/4 w-[400px] h-[400px] bg-[#00FFC8]/3 rounded-full blur-3xl"
        >
        </div>
      </div>

      <div class="relative max-w-5xl mx-auto px-6 py-28 flex flex-col sm:flex-row items-center gap-12 sm:gap-16">
        <div class="flex-1">
        <p
          class="hero-enter text-[#00FFC8] font-mono text-sm mb-5 tracking-wide"
          style="--delay: 0.1s"
        >
          Hello, I'm
        </p>

        <h1
          class="hero-enter hero-name font-bold text-[#F0F0F0] mb-5"
          style="--delay: 0.4s"
        >
          Marko Stankovic
        </h1>

        <p
          class="hero-enter text-2xl sm:text-3xl text-[#888888] font-light mb-8 cursor-blink"
          style="--delay: 0.7s"
        >
          Technical Artist · Gameplay Programmer
        </p>

        <p
          class="hero-enter text-[#888888] text-lg max-w-[520px] mb-12 leading-relaxed"
          style="--delay: 0.85s"
        >
          I build the systems that make games feel alive — AI that thinks,
          procedural worlds that surprise, editor tools that get out of the way.
          Three years deep in Unity 3D, now extending into Unreal Engine 5 and
          the art–engineering bridge. Based in Serbia, open to remote / EU.
        </p>

        <div class="hero-enter flex flex-wrap gap-4" style="--delay: 1s">
          <a
            href="#contact"
            class="px-6 py-3 bg-transparent hover:bg-[#00FFC8]/[0.08] border-[3px] border-[#00FFC8]/25 hover:border-[#00FFC8]/40 text-[#00FFC8]/80 hover:text-[#00FFC8]/100 rounded-lg font-medium transition-colors duration-150"
          >
            Let's Build
          </a>
          <a
            href="#projects"
            class="px-6 py-3 bg-transparent hover:bg-cyan-400/[0.08] border border-cyan-400/25 hover:border-cyan-400/40 text-cyan-300/80 rounded-lg font-medium transition-colors duration-150"
          >
            View Projects
          </a>
        </div>
        </div>

        <div class="hero-enter shrink-0" style="--delay: 0.6s">
          <Avatar />
        </div>
      </div>
    </section>

    <!-- ─── SKILLS ────────────────────────────────────────────────────────── -->
    <section id="skills" class="py-24 border-t border-[#1F1F1F]/50">
      <div class="max-w-5xl mx-auto px-6">
        <h2 class="reveal text-3xl font-bold text-[#F0F0F0] mb-2">Skills</h2>
        <p class="reveal text-[#888888] mb-12" style="--delay: 100ms">
          Not a stack I landed on by accident — these are the tools I reached
          for and stayed with.
        </p>

        <!-- Skill cards: 2 rows × 3 columns -->
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-2 sm:gap-4 mb-8">
          <!-- Unity 3D -->
          <div
            class="skill-card reveal bg-[#141414] border border-[#1F1F1F] rounded-xl p-3 sm:p-6 hover:border-violet-800/60 transition-colors duration-150"
            style="--card-accent: rgb(167,139,250); --card-accent-dim: rgba(139,92,246,0.18); --delay: 0ms"
          >
            <div
              class="w-9 h-9 sm:w-11 sm:h-11 bg-[#1F1F1F] rounded-lg flex items-center justify-center mb-3 sm:mb-5"
            >
              <span class="font-bold text-violet-400 font-mono text-xs sm:text-base"
                >U3D</span
              >
            </div>
            <h3 class="font-semibold text-[#F0F0F0] mb-1 text-xs sm:text-base">Unity 3D</h3>
            <p class="text-[#888888] text-[10px] sm:text-xs">3+ years</p>
          </div>

          <!-- Unreal Engine -->
          <div
            class="skill-card reveal bg-[#141414] border border-[#1F1F1F] rounded-xl p-3 sm:p-6 hover:border-blue-800/60 transition-colors duration-150"
            style="--card-accent: rgb(96,165,250); --card-accent-dim: rgba(96,165,250,0.18); --delay: 100ms"
          >
            <div
              class="w-9 h-9 sm:w-11 sm:h-11 bg-[#1F1F1F] rounded-lg flex items-center justify-center mb-3 sm:mb-5"
            >
              <span class="font-bold text-blue-400 font-mono text-xs sm:text-base">UE</span
              >
            </div>
            <h3 class="font-semibold text-[#F0F0F0] mb-1 text-xs sm:text-base">Unreal Engine 5</h3>
            <p class="text-[#888888] text-[10px] sm:text-xs">Active · migrating</p>
          </div>

          <!-- TypeScript -->
          <div
            class="skill-card reveal bg-[#141414] border border-[#1F1F1F] rounded-xl p-3 sm:p-6 hover:border-blue-800/60 transition-colors duration-150"
            style="--card-accent: rgb(96,165,250); --card-accent-dim: rgba(96,165,250,0.18); --delay: 200ms"
          >
            <div
              class="w-9 h-9 sm:w-11 sm:h-11 bg-[#1F1F1F] rounded-lg flex items-center justify-center mb-3 sm:mb-5"
            >
              <span class="font-bold text-blue-300 font-mono text-xs sm:text-base">TS</span
              >
            </div>
            <h3 class="font-semibold text-[#F0F0F0] mb-1 text-xs sm:text-base">TypeScript</h3>
            <p class="text-[#888888] text-[10px] sm:text-xs">Node · Next.js</p>
          </div>

          <!-- C# -->
          <div
            class="skill-card reveal bg-[#141414] border border-[#1F1F1F] rounded-xl p-3 sm:p-6 hover:border-green-800/60 transition-colors duration-150"
            style="--card-accent: rgb(74,222,128); --card-accent-dim: rgba(74,222,128,0.18); --delay: 300ms"
          >
            <div
              class="w-9 h-9 sm:w-11 sm:h-11 bg-[#1F1F1F] rounded-lg flex items-center justify-center mb-3 sm:mb-5"
            >
              <span class="font-bold text-green-400 font-mono text-xs sm:text-base"
                >C#</span
              >
            </div>
            <h3 class="font-semibold text-[#F0F0F0] mb-1 text-xs sm:text-base">C#</h3>
            <p class="text-[#888888] text-[10px] sm:text-xs">Primary language</p>
          </div>

          <!-- Arch Linux -->
          <div
            class="skill-card reveal bg-[#141414] border border-[#1F1F1F] rounded-xl p-3 sm:p-6 hover:border-sky-800/60 transition-colors duration-150"
            style="--card-accent: rgb(56,189,248); --card-accent-dim: rgba(56,189,248,0.18); --delay: 0ms"
          >
            <div
              class="w-9 h-9 sm:w-11 sm:h-11 bg-[#1F1F1F] rounded-lg flex items-center justify-center mb-3 sm:mb-5"
            >
              <span class="font-bold text-sky-400 font-mono text-xs sm:text-base">>_</span>
            </div>
            <h3 class="font-semibold text-[#F0F0F0] mb-1 text-xs sm:text-base">Arch Linux</h3>
            <p class="text-[#888888] text-[10px] sm:text-xs">Daily driver</p>
          </div>

          <!-- AI Tools -->
          <div
            class="skill-card reveal bg-[#141414] border border-[#1F1F1F] rounded-xl p-3 sm:p-6 hover:border-purple-800/60 transition-colors duration-150"
            style="--card-accent: rgb(192,132,252); --card-accent-dim: rgba(192,132,252,0.18); --delay: 100ms"
          >
            <div
              class="w-9 h-9 sm:w-11 sm:h-11 bg-[#1F1F1F] rounded-lg flex items-center justify-center mb-3 sm:mb-5"
            >
              <span class="font-bold text-purple-400 font-mono text-xs sm:text-base"
                >⚙</span
              >
            </div>
            <h3 class="font-semibold text-[#F0F0F0] mb-1 text-xs sm:text-base">Tooling & Automation</h3>
            <p class="text-[#888888] text-[10px] sm:text-xs">Editor tools & pipelines</p>
          </div>
        </div>

        <!-- Additional skill pills -->
        <div class="reveal flex flex-wrap gap-2.5" style="--delay: 150ms">
          {
            [
              "AI State Machines",
              "Procedural Generation",
              "Object Pooling",
              "Event-Driven Architecture",
              "Game Systems Design",
              "Editor Tooling",
              "Git / GitHub",
              "Version Control",
            ].map((skill) => (
              <span class="text-sm bg-cyan-400/[0.08] border border-[#00FFC8]/20 text-cyan-300/75 px-3 py-1.5 rounded-lg">
                {skill}
              </span>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ─── PROJECTS ──────────────────────────────────────────────────────── -->
    <section id="projects" class="py-24 border-t border-[#1F1F1F]/50">
      <div class="max-w-5xl mx-auto px-6">
        <h2 class="reveal text-3xl font-bold text-[#F0F0F0] mb-2">Projects</h2>
        <p class="reveal text-[#888888] mb-8" style="--delay: 100ms">
          Things built with intent, not just output.
        </p>

        <!-- Filter Bar — JS populates buttons -->
        <div
          id="filter-bar"
          class="reveal flex flex-nowrap sm:flex-wrap gap-2 overflow-x-auto sm:overflow-x-visible py-2 mb-10"
          role="group"
          aria-label="Filter projects by tag"
          style="--delay: 150ms"
        >
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
          <!-- Endless Runner -->
          <article
            class="project-card reveal bg-[#141414] border border-[#1F1F1F] rounded-xl overflow-hidden hover:border-cyan-800/50 transition-colors duration-150 flex flex-col"
            style="--card-glow: rgba(34,211,238,0.1); --delay: 0ms"
            data-tags="Proc Gen,Object Pooling,Event-Driven,Utility Scripts,Lane Movement,C#"
            data-screenshots={`${endlessRunner1.src},${endlessRunner2.src}`}
          >
            <!-- 16:9 thumbnail -->
            <div
              class="thumb-wrap w-full aspect-video shrink-0 cursor-pointer relative"
              role="button"
              tabindex="0"
              aria-label="Open Endless Runner screenshots"
            >
              <video
                class="w-full h-full object-cover"
                autoplay
                loop
                muted
                playsinline
                preload="none"
                poster={endlessRunner1.src}
              >
                <source
                  src="/assets/thumbnails/endless-runner-thumb.mp4"
                  type="video/mp4"
                />
              </video>
            </div>

            <!-- Card content -->
            <div class="p-8 flex flex-col flex-1">
              <header class="flex items-start justify-between mb-5">
                <span
                  class="text-xs font-mono bg-[#00FFC8]/[0.08] text-[#00FFC8]/75 border border-[#00FFC8]/20 px-3 py-1 rounded-full"
                >
                  Completed
                </span>
                <span class="text-xs text-[#666666] font-mono">Unity 3D</span>
              </header>

              <h3 class="text-xl font-bold text-[#F0F0F0] mb-3">
                Relic Rush
              </h3>

              <p class="text-[#888888] text-sm leading-relaxed mb-5 flex-1">
                Infinite levels, zero GC spikes. Chunk-based proc gen with a
                queue-based object pool — event-driven architecture keeps
                spawning, scoring, and audio fully decoupled.
              </p>

              <div class="flex flex-wrap gap-2 mb-6">
                {
                  [
                    "Proc Gen",
                    "Object Pooling",
                    "Event-Driven",
                    "Utility Scripts",
                    "Lane Movement",
                    "C#",
                  ].map((tag) => (
                    <span class="project-tag text-xs bg-cyan-400/[0.08] border border-[#00FFC8]/20 text-cyan-300/75 px-2 py-1 rounded">
                      {tag}
                    </span>
                  ))
                }
              </div>

              <!-- CTAs -->
              <div class="flex flex-wrap gap-3">
                <a
                  href="https://github.com/Idzuo32/relic-rush"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 px-4 py-2.5 rounded-lg bg-transparent hover:bg-cyan-400/[0.08] border border-cyan-400/15 hover:border-cyan-400/30 text-sm text-cyan-300/55 hover:text-cyan-300/75 transition-colors duration-150 min-h-[44px]"
                >
                  View on GitHub
                  <svg
                    class="arrow w-4 h-4"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                  </svg>
                </a>
                <a
                  href="/projects/endless-runner"
                  class="inline-flex items-center gap-2 px-4 py-2.5 rounded-lg bg-transparent hover:bg-[#00FFC8]/[0.08] border-[3px] border-[#00FFC8]/25 hover:border-[#00FFC8]/40 text-[#00FFC8]/80 text-sm transition-colors duration-150 min-h-[44px]"
                >
                  View Details →
                </a>
              </div>
            </div>
          </article>

          <!-- DeployLog -->
          <article
            class="project-card reveal bg-[#141414] border border-[#1F1F1F] rounded-xl overflow-hidden hover:border-rose-800/50 transition-colors duration-150 flex flex-col"
            style="--card-glow: rgba(230,57,70,0.1); --delay: 150ms"
            data-tags="SaaS,Next.js,TypeScript,Supabase,Stripe,CLI"
            data-screenshots={deploylog1.src}
          >
            <!-- 16:9 thumbnail -->
            <div
              class="thumb-wrap w-full aspect-video shrink-0 cursor-pointer relative"
              role="button"
              tabindex="0"
              aria-label="Open DeployLog screenshot"
            >
              <img
                class="w-full h-full object-cover"
                src={deploylog1.src}
                alt="DeployLog landing page"
                loading="lazy"
              />
            </div>

            <!-- Card content -->
            <div class="p-8 flex flex-col flex-1">
              <header class="flex items-start justify-between mb-5">
                <span
                  class="text-xs font-mono bg-[#00FFC8]/[0.08] text-[#00FFC8]/75 border border-[#00FFC8]/20 px-3 py-1 rounded-full"
                >
                  Launching
                </span>
                <span class="text-xs text-[#666666] font-mono">Next.js · SaaS</span>
              </header>

              <h3 class="text-xl font-bold text-[#F0F0F0] mb-3">DeployLog</h3>

              <p class="text-[#888888] text-sm leading-relaxed mb-5 flex-1">
                A changelog &amp; release-notes platform for dev teams — hosted
                page, embeddable widget, and a published npm CLI that turns git
                commits into release notes with an LLM. Built full-stack:
                Next.js, Supabase, Stripe.
              </p>

              <div class="flex flex-wrap gap-2 mb-6">
                {
                  [
                    "SaaS",
                    "Next.js",
                    "TypeScript",
                    "Supabase",
                    "Stripe",
                    "CLI",
                  ].map((tag) => (
                    <span class="project-tag text-xs bg-cyan-400/[0.08] border border-[#00FFC8]/20 text-cyan-300/75 px-2 py-1 rounded">
                      {tag}
                    </span>
                  ))
                }
              </div>

              <!-- CTAs -->
              <div class="flex flex-wrap gap-3">
                <a
                  href="https://deploylog.dev"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 px-4 py-2.5 rounded-lg bg-transparent hover:bg-cyan-400/[0.08] border border-cyan-400/15 hover:border-cyan-400/30 text-sm text-cyan-300/55 hover:text-cyan-300/75 transition-colors duration-150 min-h-[44px]"
                >
                  Visit site
                  <svg
                    class="arrow w-4 h-4"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
