  <!-- ─── LIGHTBOX ─────────────────────────────────────────────────────── -->
  <div
    id="lightbox"
    role="dialog"
    aria-modal="true"
    aria-label="Screenshot viewer"
    class="fixed inset-0 z-[200] items-center justify-center"
  >
    <!-- Backdrop -->
    <div id="lightbox-backdrop" class="absolute inset-0 bg-[#0D0D0D]/95"></div>

    <!-- Content row: prev · image · next -->
    <div
      id="lightbox-content"
      class="relative z-10 flex items-center gap-3 px-4"
    >
      <button
        id="lightbox-prev"
        class="lb-btn"
        aria-label="Previous screenshot"
      >
        <svg
          width="20"
          height="20"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M15 19l-7-7 7-7"></path>
        </svg>
      </button>

      <img id="lightbox-img" src="data:," alt="Project screenshot" />

      <button id="lightbox-next" class="lb-btn" aria-label="Next screenshot">
        <svg
          width="20"
          height="20"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"
          ></path>
        </svg>
      </button>
    </div>

    <!-- Close button -->
    <button id="lightbox-close" class="lb-btn z-10" aria-label="Close lightbox">
      <svg
        width="20"
        height="20"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        viewBox="0 0 24 24"
        aria-hidden="true"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
  </div>

  <script>
    const prefersReduced = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;

    // ─── Scroll Reveal ──────────────────────────────────────────────────
    const revealEls = document.querySelectorAll(".reveal");

    if (!prefersReduced) {
      const revealObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("visible");
              revealObserver.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.15 },
      );
      revealEls.forEach((el) => revealObserver.observe(el));
    } else {
      revealEls.forEach((el) => el.classList.add("visible"));
    }

    // ─── Active Nav Section ─────────────────────────────────────────────
    const navLinks = document.querySelectorAll('.nav-link[href^="#"]');
    const sections = document.querySelectorAll("section[id]");
    const sectionIds = Array.from(sections).map((s) => s.id);
    const activeSet = new Set<string>();

    const sectionObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) activeSet.add(entry.target.id);
          else activeSet.delete(entry.target.id);
        });

        const topId = sectionIds.find((id) => activeSet.has(id));

        navLinks.forEach((link) => {
          link.classList.toggle(
            "nav-active",
            link.getAttribute("href") === `#${topId}`,
          );
        });
      },
      { rootMargin: "-20% 0px -50% 0px" },
    );

    sections.forEach((s) => sectionObserver.observe(s));

    // ─── Hamburger Nav ──────────────────────────────────────────────────
    const menuBtn = document.getElementById("menu-btn");
    const mobileNav = document.getElementById("mobile-nav");
    const iconMenu = document.getElementById("icon-menu");
    const iconClose = document.getElementById("icon-close");

    const mobileNavLinks =
      document.querySelectorAll<HTMLElement>(".mobile-nav-link");

    function closeMobileNav() {
      mobileNav?.classList.remove("open");
      mobileNav?.setAttribute("aria-hidden", "true");
      menuBtn?.setAttribute("aria-expanded", "false");
      iconMenu?.classList.remove("hidden");
      iconClose?.classList.add("hidden");
      mobileNavLinks.forEach((link) => link.setAttribute("tabindex", "-1"));
    }

    menuBtn?.addEventListener("click", () => {
      const isOpen = mobileNav?.classList.toggle("open");
      menuBtn.setAttribute("aria-expanded", String(isOpen));
      iconMenu?.classList.toggle("hidden", !!isOpen);
      iconClose?.classList.toggle("hidden", !isOpen);
      if (isOpen) {
        mobileNav?.removeAttribute("aria-hidden");
        mobileNavLinks.forEach((link) => link.removeAttribute("tabindex"));
      } else {
        mobileNav?.setAttribute("aria-hidden", "true");
        mobileNavLinks.forEach((link) => link.setAttribute("tabindex", "-1"));
      }
    });

    // Close mobile nav when a link is clicked
    document.querySelectorAll(".mobile-nav-link").forEach((link) => {
      link.addEventListener("click", closeMobileNav);
    });

    // ─── Filter Bar ─────────────────────────────────────────────────────
    const filterBar = document.getElementById("filter-bar");
    const projectCards =
      document.querySelectorAll<HTMLElement>(".project-card");

    if (filterBar) {
      // Collect unique tags from project tags
      const tagSet = new Set<string>();
      document.querySelectorAll(".project-tag").forEach((el) => {
        const t = el.textContent?.trim();
        if (t) tagSet.add(t);
      });

      const tags = ["All", ...Array.from(tagSet).sort()];

      tags.forEach((tag) => {
        const btn = document.createElement("button");
        btn.textContent = tag;
        btn.dataset.filter = tag;
        btn.className = "filter-btn";
        if (tag === "All") btn.classList.add("active");
        filterBar.appendChild(btn);
      });

      filterBar.addEventListener("click", (e) => {
        const btn = (e.target as HTMLElement).closest<HTMLButtonElement>(
          ".filter-btn",
        );
        if (!btn) return;

        const filter = btn.dataset.filter ?? "All";

        document
          .querySelectorAll(".filter-btn")
          .forEach((b) => b.classList.remove("active"));
        btn.classList.add("active");

        projectCards.forEach((card) => {
          if (filter === "All") {
            card.classList.remove("filtered-out");
          } else {
            const cardTags = (card.dataset.tags ?? "")
              .split(",")
              .map((t) => t.trim());
            card.classList.toggle("filtered-out", !cardTags.includes(filter));
          }
        });
      });
    }

    // ─── Video Lazy Load (IntersectionObserver) ──────────────────────────
    const thumbVideos =
      document.querySelectorAll<HTMLVideoElement>(".thumb-wrap video");

    const videoObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const video = entry.target as HTMLVideoElement;
          if (entry.isIntersecting) {
            if (video.readyState === 0) video.load();
            video.play().catch(() => {});
          } else {
            video.pause();
          }
        });
      },
      { threshold: 0.25 },
    );

    thumbVideos.forEach((v) => videoObserver.observe(v));

    // ─── Lightbox ────────────────────────────────────────────────────────
    const lightbox = document.getElementById("lightbox")!;
    const lbImg = document.getElementById("lightbox-img") as HTMLImageElement;
    const lbPrev = document.getElementById(
      "lightbox-prev",
    ) as HTMLButtonElement;
    const lbNext = document.getElementById(
      "lightbox-next",
    ) as HTMLButtonElement;
    const lbClose = document.getElementById("lightbox-close")!;
    const lbBackdrop = document.getElementById("lightbox-backdrop")!;

    let lbScreenshots: string[] = [];
    let lbIndex = 0;
    let lbPrevFocus: HTMLElement | null = null;

    const lbFocusable = () =>
      Array.from(
        lightbox.querySelectorAll<HTMLElement>("button, img[tabindex]"),
      ).filter((el) => !el.hasAttribute("disabled"));

    function lbShow(screenshots: string[], startIndex: number) {
      lbScreenshots = screenshots;
      lbIndex = startIndex;
      lbPrevFocus = document.activeElement as HTMLElement;
      lbUpdate();
      lightbox.style.display = "flex";
      // Force reflow then add open class for transition
      lightbox.getBoundingClientRect();
      lightbox.classList.add("lb-open");
      document.body.style.overflow = "hidden";
      lbClose.focus();
    }

    function lbHide() {
      lightbox.classList.remove("lb-open");
      // Wait for transition then hide
      lightbox.addEventListener(
        "transitionend",
        () => {
          lightbox.style.display = "none";
          document.body.style.overflow = "";
          lbPrevFocus?.focus();
        },
        { once: true },
      );
    }

    function lbUpdate() {
      lbImg.src = lbScreenshots[lbIndex];
      lbImg.alt = `Screenshot ${lbIndex + 1} of ${lbScreenshots.length}`;
      lbPrev.disabled = lbIndex === 0;
      lbNext.disabled = lbIndex === lbScreenshots.length - 1;
    }

    // Open lightbox when a thumb-wrap is clicked/keydown
    document.querySelectorAll<HTMLElement>(".thumb-wrap").forEach((wrap) => {
      const openLightbox = () => {
        const card = wrap.closest<HTMLElement>("[data-screenshots]");
        if (!card) return;
        const shots = (card.dataset.screenshots ?? "")
          .split(",")
          .map((s) => s.trim())
          .filter(Boolean);
        if (!shots.length) return;
        lbShow(shots, 0);
      };

      wrap.addEventListener("click", openLightbox);
      wrap.addEventListener("keydown", (e) => {
        if (e.key === "Enter" || e.key === " ") {
          e.preventDefault();
          openLightbox();
        }
      });
    });

    lbClose.addEventListener("click", lbHide);
    lbBackdrop.addEventListener("click", lbHide);

    lbPrev.addEventListener("click", () => {
      if (lbIndex > 0) {
        lbIndex--;
        lbUpdate();
      }
    });

    lbNext.addEventListener("click", () => {
      if (lbIndex < lbScreenshots.length - 1) {
        lbIndex++;
        lbUpdate();
      }
    });

    // Keyboard navigation
    lightbox.addEventListener("keydown", (e) => {
      if (e.key === "Escape") {
        lbHide();
      } else if (e.key === "ArrowLeft") {
        if (lbIndex > 0) {
          lbIndex--;
          lbUpdate();
        }
      } else if (e.key === "ArrowRight") {
        if (lbIndex < lbScreenshots.length - 1) {
          lbIndex++;
          lbUpdate();
        }
      } else if (e.key === "Tab") {
        // Focus trap
        const focusable = lbFocusable();
        const first = focusable[0];
        const last = focusable[focusable.length - 1];
        if (e.shiftKey) {
          if (document.activeElement === first) {
            e.preventDefault();
            last.focus();
          }
        } else {
          if (document.activeElement === last) {
            e.preventDefault();
            first.focus();
          }
        }
      }
    });

    // ─── Contact Form ────────────────────────────────────────────────────
    const contactForm = document.getElementById(
      "contact-form",
    ) as HTMLFormElement | null;
    const formSuccess = document.getElementById("form-success");

    contactForm?.addEventListener("submit", async (e) => {
      e.preventDefault();

      const submitBtn = contactForm.querySelector(
        '[type="submit"]',
      ) as HTMLButtonElement;
      submitBtn.disabled = true;
      submitBtn.textContent = "Sending…";

      try {
        const res = await fetch(contactForm.action, {
          method: "POST",
          body: new FormData(contactForm),
          headers: { Accept: "application/json" },
        });

        if (res.ok) {
          contactForm.classList.add("hidden");
          formSuccess?.classList.remove("hidden");
        } else {
          submitBtn.disabled = false;
          submitBtn.textContent = "Send Message";
          alert("Something went wrong. Please try again.");
        }
      } catch {
        submitBtn.disabled = false;
        submitBtn.textContent = "Send Message";
        alert("Network error. Please try again.");
      }
    });
  </script>
</BaseLayout>
