---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const recentPosts = (await getCollection("blog"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3)
  .map((post) => {
    const words = (post.body ?? "").split(/\s+/).filter(Boolean).length;
    return { ...post, readingTime: Math.max(1, Math.ceil(words / 200)) };
  });

const pageTitle = "Marko Stankovic | I build software products and ship them";
const pageDescription =
  "Solo developer. DeployLog turns deploys into release notes. Habitagram turns your habits into a journey. A homegrown generative media studio renders the art for both.";

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Marko Stankovic",
  url: "https://markostankovic.org",
  jobTitle: "Solo Developer",
  sameAs: [
    "https://github.com/marko-builds",
    "https://www.linkedin.com/in/marko-builds/",
    "https://www.instagram.com/marko.builds/",
  ],
};

const dateFmt = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "2-digit" });
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
  </Fragment>

  <div class="rails" aria-hidden="true">
    <span class="cross c1">+</span><span class="cross c2">+</span>
    <span class="cross c3">+</span><span class="cross c4">+</span>
  </div>

  <main id="main">
    <!-- HERO -->
    <section class="hero">
      <div class="frame">
        <p class="repl kinetic k1">
          <span class="chevron">&gt;</span> MarkoStankovic(<span class="arg">Developer</span>)<span class="semi">;</span><span class="cursor-blink"></span>
        </p>

        <h1 class="headline">
          <span class="kinetic k2">I build software products</span>
          <span class="kinetic k3 outline">and ship them.</span>
        </h1>

        <p class="sub kinetic k4">
          DeployLog turns deploys into release notes. Habitagram turns your
          habits into a journey. A homegrown generative media studio renders
          the art for both.
        </p>

        <div class="ctas kinetic k5">
          <a class="btn-fill" href="#work">See the work</a>
          <a class="btn-ghost" href="/devlog">Read the devlog</a>
        </div>
      </div>
    </section>

    <!-- PRODUCTS -->
    <section class="band" id="work">
      <div class="frame">
        <h2 class="section-label io mask"><span>Products</span></h2>

        <div class="cards io">
          <a class="card" href="/projects/deploylog/">
            <div class="card-top">
              <span class="dot live"></span>
              <span class="label">deploylog</span>
            </div>
            <p>Release notes from your deploys.</p>
            <span class="status live">status: launching</span>
          </a>
          <div class="card">
            <div class="card-top">
              <span class="dot warm"></span>
              <span class="label">habitagram</span>
            </div>
            <p>Habit tracking as a journey.</p>
            <span class="status">status: near launch</span>
          </div>
          <a class="card" href="/devlog/">
            <div class="card-top">
              <span class="dot idle"></span>
              <span class="label">studio</span>
            </div>
            <p>The generative media engine behind both.</p>
            <span class="status">status: internal</span>
          </a>
        </div>
      </div>
    </section>

    <!-- ABOUT -->
    <section class="band" id="about">
      <div class="frame">
        <h2 class="section-label io mask"><span>About</span></h2>
        <p class="about-text io">
          I'm Marko, a solo developer. I spent three years building game
          systems in Unity and Unreal, then turned the same craft on my own
          products. Now I ship small software with an AI-heavy workflow: two
          apps in flight, and a generative studio that renders their art,
          video, and sound. I write about the process on the devlog.
        </p>
      </div>
    </section>

    <!-- DEVLOG -->
    {
      recentPosts.length > 0 && (
        <section class="band" id="devlog">
          <div class="frame">
            <div class="band-head">
              <h2 class="section-label io mask">
                <span>Devlog</span>
              </h2>
              <a class="all-link" href="/devlog">All posts</a>
            </div>
            <div class="post-rows io">
              {recentPosts.map((post) => (
                <a class="post-row" href={`/devlog/${post.slug}/`}>
                  <span class="post-date">{dateFmt(post.data.date)}</span>
                  <span class="post-title">{post.data.title}</span>
                  <span class="post-time">{post.readingTime} min</span>
                </a>
              ))}
            </div>
          </div>
        </section>
      )
    }

    <!-- CONTACT -->
    <section class="band" id="contact">
      <div class="frame">
        <h2 class="section-label io mask"><span>Contact</span></h2>
        <p class="band-intro io">
          Building something similar, or want to compare notes? My inbox is open.
        </p>
        <div class="contact-rows io">
          <a class="contact-row" href="mailto:contact@markostankovic.org">
            <span class="mono-meta">email</span>
            <span>contact@markostankovic.org</span>
          </a>
          <a class="contact-row" href="https://github.com/marko-builds" target="_blank" rel="noopener noreferrer">
            <span class="mono-meta">github</span>
            <span>github.com/marko-builds</span>
          </a>
          <a class="contact-row" href="https://www.linkedin.com/in/marko-builds/" target="_blank" rel="noopener noreferrer">
            <span class="mono-meta">linkedin</span>
            <span>marko-builds</span>
          </a>
        </div>
      </div>
    </section>
  </main>

  <footer>
    <div class="frame foot">
      <p>&copy; 2026 Marko Stankovic</p>
      <p class="mono-meta">Developer &middot; Serbia</p>
    </div>
  </footer>
</BaseLayout>

<style>
  /* Vercel-monochrome direction (issue 03 pick). Colors are the frozen brand
     tokens or alpha/blend derivations of them; no new hues. */

  .rails {
    position: fixed;
    inset: 0 max(24px, calc(50vw - 560px));
    border-left: 1px solid var(--color-border);
    border-right: 1px solid var(--color-border);
    pointer-events: none;
    z-index: 1;
  }
  .cross {
    position: absolute;
    font-family: var(--font-mono);
    color: var(--color-text-muted);
    font-size: 14px;
    transform: translate(-50%, -50%);
  }
  .c1 { top: 14vh; left: 0; }
  .c2 { top: 14vh; right: 0; transform: translate(50%, -50%); }
  .c3 { bottom: 10vh; left: 0; transform: translate(-50%, 50%); }
  .c4 { bottom: 10vh; right: 0; transform: translate(50%, 50%); }

  .frame {
    max-width: 1000px;
    margin: 0 auto;
    padding-inline: 56px;
  }
  @media (max-width: 720px) {
    .frame { padding-inline: 28px; }
  }

  /* HERO */
  .hero {
    padding-block: 148px 104px;
    background:
      linear-gradient(#1f1f1f80 1px, transparent 1px) 0 0 / 100% 96px,
      linear-gradient(90deg, #1f1f1f80 1px, transparent 1px) 0 0 / 96px 100%;
  }
  .repl {
    font-family: var(--font-mono);
    font-size: 14px;
    color: var(--color-text-primary);
    margin: 0 0 40px;
  }
  @media (max-width: 380px) {
    .repl { font-size: 12px; }
  }
  .chevron { color: var(--color-accent); }
  .arg { color: var(--color-text-secondary); }
  .semi { color: var(--color-text-muted); }

  .headline {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: clamp(2.8rem, 7vw, 5.4rem);
    line-height: 1.04;
    letter-spacing: -0.045em;
    color: var(--color-text-primary);
    margin: 0 0 28px;
  }
  .headline span { display: block; }
  .outline {
    color: transparent;
    -webkit-text-stroke: 1.5px var(--color-text-secondary);
  }

  .sub {
    color: var(--color-text-secondary);
    font-size: 17px;
    line-height: 1.7;
    max-width: 56ch;
    margin: 0 0 48px;
  }

  .ctas { display: flex; flex-wrap: wrap; gap: 14px; }
  .btn-fill,
  .btn-ghost {
    font-size: 15px;
    font-weight: 500;
    text-decoration: none;
    padding: 12px 24px;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    transition: background-color 0.15s ease, border-color 0.15s ease;
  }
  .btn-fill { background: var(--color-text-primary); color: var(--color-bg); }
  .btn-fill:hover { background: #cfcfcf; }
  .btn-ghost {
    color: var(--color-text-primary);
    border: 1px solid var(--color-border-strong);
  }
  .btn-ghost:hover { border-color: var(--color-text-secondary); }

  /* SECTIONS */
  .band {
    border-top: 1px solid var(--color-border);
    padding-block: 88px;
  }
  .section-label {
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    margin: 0 0 36px;
  }
  .section-label::before { content: "// "; color: var(--color-accent); }
  .band-intro {
    color: var(--color-text-secondary);
    font-size: 16px;
    line-height: 1.7;
    max-width: 56ch;
    margin: -16px 0 40px;
  }

  /* mask-reveal heading (P14 vocabulary, CSS dialect) */
  .mask { overflow: hidden; }
  .mask span {
    display: inline-block;
    transform: translateY(120%);
    transition: transform 0.6s cubic-bezier(0.2, 0.7, 0.2, 1);
  }
  .mask.in span { transform: none; }

  /* PRODUCTS */
  .cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--color-border-strong);
    border: 1px solid var(--color-border-strong);
  }
  @media (max-width: 720px) {
    .cards { grid-template-columns: 1fr; }
  }
  .card {
    display: flex;
    flex-direction: column;
    background: var(--color-bg);
    padding: 22px;
    text-decoration: none;
    transition: background-color 0.15s ease;
  }
  a.card:hover { background: var(--color-surface); }
  .card-top { display: flex; align-items: center; gap: 8px; margin-bottom: 12px; }
  .dot { width: 8px; height: 8px; border-radius: 50%; }
  .dot.live { background: var(--color-warm); box-shadow: 0 0 8px var(--color-warm); }
  .dot.warm { background: var(--color-text-primary); }
  .dot.idle { background: var(--color-text-muted); }
  .label { font-family: var(--font-mono); font-size: 13px; color: var(--color-text-primary); }
  .card p { margin: 0 0 16px; font-size: 14px; color: var(--color-text-secondary); line-height: 1.55; }
  .status { font-family: var(--font-mono); font-size: 11px; color: var(--color-text-muted); margin-top: auto; }
  .status.live { color: var(--color-warm); }

  /* shared mono meta label */
  .mono-meta {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin: 0 0 10px;
  }
  /* ABOUT */
  .about-text {
    color: var(--color-text-secondary);
    font-size: 17px;
    line-height: 1.8;
    max-width: 62ch;
    margin: 0;
  }

  /* DEVLOG */
  .band-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
  }
  .all-link {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--color-text-secondary);
    text-decoration: none;
  }
  .all-link:hover { color: var(--color-text-primary); }
  .post-rows { border-top: 1px solid var(--color-border); }
  .post-row {
    display: grid;
    grid-template-columns: 110px 1fr auto;
    gap: 20px;
    align-items: baseline;
    padding: 16px 4px;
    border-bottom: 1px solid var(--color-border);
    text-decoration: none;
    transition: background-color 0.15s ease;
  }
  .post-row:hover { background: var(--color-surface); }
  .post-date, .post-time {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-text-muted);
    white-space: nowrap;
  }
  .post-title { font-size: 15px; color: var(--color-text-primary); }
  @media (max-width: 720px) {
    .post-row { grid-template-columns: 1fr auto; }
    .post-date { display: none; }
  }

  /* CONTACT */
  .contact-rows { border-top: 1px solid var(--color-border); max-width: 560px; }
  .contact-row {
    display: grid;
    grid-template-columns: 90px 1fr;
    gap: 20px;
    align-items: baseline;
    padding: 14px 4px;
    border-bottom: 1px solid var(--color-border);
    text-decoration: none;
    font-size: 15px;
    color: var(--color-text-primary);
    transition: background-color 0.15s ease;
    min-height: 44px;
  }
  .contact-row:hover { background: var(--color-surface); }
  .contact-row .mono-meta { margin: 0; }

  /* FOOTER */
  footer { border-top: 1px solid var(--color-border); }
  .foot {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: 8px;
    padding-block: 28px;
  }
  .foot p { margin: 0; font-size: 13px; color: var(--color-text-secondary); }
  .foot .mono-meta { margin: 0; }

  /* MOTION (P14 vocabulary, CSS dialect): kinetic hero on load, io reveals on scroll */
  .kinetic { animation: rise 0.6s ease-out both; }
  .k1 { animation-delay: 0.05s; }
  .k2 { animation-delay: 0.12s; }
  .k3 { animation-delay: 0.19s; }
  .k4 { animation-delay: 0.26s; }
  .k5 { animation-delay: 0.33s; }
  @keyframes rise {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: none; }
  }
  .io:not(.mask) {
    opacity: 0;
    transform: translateY(14px);
    transition: opacity 0.55s ease-out, transform 0.55s cubic-bezier(0.2, 0.7, 0.2, 1);
  }
  .io.in:not(.mask) { opacity: 1; transform: none; }

  @media (prefers-reduced-motion: reduce) {
    .kinetic { animation: none; }
    .io:not(.mask) { opacity: 1; transform: none; transition: none; }
    .mask span { transform: none; transition: none; }
    :global(.cursor-blink::after) { animation: none; }
  }
</style>

<script>
  // The one home-page script: scroll reveals + the count-up utility
  // (P14 stat-counter dialect; consumed by any [data-count] element).
  const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  const countUp = (el: HTMLElement) => {
    const target = Number(el.dataset.count || "0");
    if (reduced || !target) {
      el.textContent = String(target);
      return;
    }
    const t0 = performance.now();
    const dur = 900;
    const tick = (t: number) => {
      const p = Math.min(1, (t - t0) / dur);
      el.textContent = String(Math.round(target * (1 - Math.pow(1 - p, 3))));
      if (p < 1) requestAnimationFrame(tick);
    };
    requestAnimationFrame(tick);
  };

  const els = document.querySelectorAll<HTMLElement>(".io");
  if (reduced || !("IntersectionObserver" in window)) {
    els.forEach((el) => el.classList.add("in"));
    document.querySelectorAll<HTMLElement>("[data-count]").forEach(countUp);
  } else {
    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (!e.isIntersecting) continue;
          e.target.classList.add("in");
          (e.target as HTMLElement)
            .querySelectorAll<HTMLElement>("[data-count]")
            .forEach(countUp);
          io.unobserve(e.target);
        }
      },
      { threshold: 0.15, rootMargin: "0px 0px -40px 0px" },
    );
    els.forEach((el) => io.observe(el));
  }
</script>
