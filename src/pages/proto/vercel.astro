---
// Throwaway direction prototype (issue 03): VERCEL-MONOCHROME.
// Grid lines, terminal/code motifs, sharp contrast. Mint only as prompt/status accents.
// Copy is DRAFT ONLY; issue 04 owns approval. Delete this page after the pick.
import '../../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>Proto: Vercel-monochrome</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&family=JetBrains+Mono:ital,wght@0,400;0,500;0,600;0,700&display=swap"
    />
  </head>
  <body>
    <div class="rails" aria-hidden="true">
      <span class="cross c1">+</span><span class="cross c2">+</span>
      <span class="cross c3">+</span><span class="cross c4">+</span>
    </div>

    <main class="frame">
      <div class="prompt reveal">
        <span class="dollar">$</span> whoami<br />
        <span class="answer">marko stankovic, builder</span><span class="cursor-blink"></span>
      </div>

      <h1 class="headline reveal">
        I build my own products<br />
        <span class="outline">and ship them.</span>
      </h1>

      <p class="sub reveal">
        DeployLog turns deploys into release notes. Habitagram turns habits into
        a journey. A homegrown generative studio renders the art for both.
      </p>

      <div class="cards reveal">
        <div class="card">
          <div class="card-top">
            <span class="dot live"></span>
            <span class="label">deploylog</span>
          </div>
          <p>Release notes from your deploys</p>
          <span class="status">status: launching</span>
        </div>
        <div class="card">
          <div class="card-top">
            <span class="dot warm"></span>
            <span class="label">habitagram</span>
          </div>
          <p>Habit tracking as a journey</p>
          <span class="status">status: near launch</span>
        </div>
        <div class="card">
          <div class="card-top">
            <span class="dot idle"></span>
            <span class="label">studio</span>
          </div>
          <p>Generative media engine behind both</p>
          <span class="status">status: internal</span>
        </div>
      </div>

      <div class="ctas reveal">
        <a class="btn-fill" href="#work">See the work</a>
        <a class="btn-ghost" href="#devlog">Read the devlog</a>
      </div>
    </main>

    <style>
      body {
        margin: 0;
        font-family: var(--font-sans);
        min-height: 100vh;
        background:
          linear-gradient(var(--color-border) 1px, transparent 1px) 0 0 / 100% 96px,
          linear-gradient(90deg, var(--color-border) 1px, transparent 1px) 0 0 / 96px 100%,
          var(--color-bg);
        background-blend-mode: normal;
      }
      body::before { display: none; }

      .rails {
        position: fixed;
        inset: 0 max(24px, calc(50vw - 560px));
        border-left: 1px solid var(--color-border-strong);
        border-right: 1px solid var(--color-border-strong);
        pointer-events: none;
      }
      .cross {
        position: absolute;
        font-family: var(--font-mono);
        color: var(--color-text-muted);
        font-size: 14px;
        transform: translate(-50%, -50%);
      }
      .c1 { top: 12vh; left: 0; }
      .c2 { top: 12vh; right: 0; transform: translate(50%, -50%); }
      .c3 { bottom: 8vh; left: 0; transform: translate(-50%, 50%); }
      .c4 { bottom: 8vh; right: 0; transform: translate(50%, 50%); }

      .frame {
        max-width: 1000px;
        margin: 0 auto;
        padding: 14vh 56px 96px;
      }
      .prompt {
        font-family: var(--font-mono);
        font-size: 14px;
        color: var(--color-text-secondary);
        margin-bottom: 40px;
      }
      .dollar { color: var(--color-accent); }
      .answer { color: var(--color-text-primary); }

      .headline {
        font-family: var(--font-sans);
        font-weight: 700;
        font-size: clamp(2.8rem, 7vw, 5.4rem);
        line-height: 1.02;
        letter-spacing: -0.045em;
        color: var(--color-text-primary);
        margin: 0 0 28px;
      }
      .outline {
        color: transparent;
        -webkit-text-stroke: 1.5px var(--color-text-secondary);
      }

      .sub {
        color: var(--color-text-secondary);
        font-size: 17px;
        line-height: 1.7;
        max-width: 56ch;
        margin: 0 0 56px;
      }

      .cards {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1px;
        background: var(--color-border-strong);
        border: 1px solid var(--color-border-strong);
        margin-bottom: 56px;
      }
      .card {
        background: var(--color-bg);
        padding: 20px;
      }
      .card:hover { background: var(--color-surface); }
      .card-top {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 10px;
      }
      .dot { width: 8px; height: 8px; border-radius: 50%; }
      .dot.live { background: var(--color-accent); box-shadow: 0 0 8px var(--color-accent); }
      .dot.warm { background: #f5c33b; }
      .dot.idle { background: var(--color-text-muted); }
      .label {
        font-family: var(--font-mono);
        font-size: 13px;
        color: var(--color-text-primary);
      }
      .card p {
        margin: 0 0 14px;
        font-size: 14px;
        color: var(--color-text-secondary);
        line-height: 1.55;
      }
      .status {
        font-family: var(--font-mono);
        font-size: 11px;
        color: var(--color-text-muted);
      }

      .ctas { display: flex; gap: 14px; }
      .btn-fill,
      .btn-ghost {
        font-size: 15px;
        font-weight: 500;
        text-decoration: none;
        padding: 11px 24px;
        border-radius: 0;
      }
      .btn-fill { background: var(--color-text-primary); color: #0d0d0d; }
      .btn-fill:hover { background: #cfcfcf; }
      .btn-ghost {
        color: var(--color-text-primary);
        border: 1px solid var(--color-border-strong);
      }
      .btn-ghost:hover { border-color: var(--color-text-secondary); }

      .reveal { animation: rise 0.6s ease-out both; }
      .reveal:nth-child(2) { animation-delay: 0.07s; }
      .reveal:nth-child(3) { animation-delay: 0.14s; }
      .reveal:nth-child(4) { animation-delay: 0.21s; }
      .reveal:nth-child(5) { animation-delay: 0.28s; }
      @keyframes rise {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: none; }
      }
      @media (prefers-reduced-motion: reduce) {
        .reveal { animation: none; }
        .cursor-blink::after { animation: none; }
      }
      @media (max-width: 720px) {
        .cards { grid-template-columns: 1fr; }
        .frame { padding: 10vh 28px 64px; }
      }
    </style>
  </body>
</html>
