---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteNav from "../../components/SiteNav.astro";

const allPosts = await getCollection("blog");
const posts = allPosts
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .map((post) => {
    const words = (post.body ?? "").split(/\s+/).filter(Boolean).length;
    return {
      ...post,
      readingTime: Math.max(1, Math.ceil(words / 200)),
      slug: post.slug,
    };
  });

const allTags = [...new Set(posts.flatMap((p) => p.data.tags))].sort();

const pageTitle = "Devlog | Marko Stankovic";
const pageDescription =
  "Build notes from the products, the studio, and the occasional game system.";

const dateFmt = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "2-digit" });
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <SiteNav active="devlog" />

  <main class="pt-14">
    <div class="head-band">
      <div class="frame">
        <h1 class="hero-enter">// Devlog</h1>
        <p class="hero-enter sub">
          Build notes from the products, the studio, and the occasional game system.
        </p>
      </div>
    </div>

    <section class="list-band">
      <div class="frame">
        <h2 class="sr-only">Posts</h2>

        <div class="tag-bar" role="group" aria-label="Filter posts by tag">
          <button class="tag-btn active" data-tag="all">all</button>
          {allTags.map((tag) => <button class="tag-btn" data-tag={tag}>{tag}</button>)}
        </div>

        <div class="post-rows">
          {
            posts.map((post) => (
              <a class="post-row" href={`/devlog/${post.slug}/`} data-tags={post.data.tags.join(",")}>
                <div class="row-meta">
                  <span class="post-date">{dateFmt(post.data.date)}</span>
                  <span class="post-time">{post.readingTime} min</span>
                </div>
                <div class="row-main">
                  <span class="post-title">{post.data.title}</span>
                  <span class="post-excerpt">{post.data.excerpt}</span>
                  <span class="post-tags">
                    {post.data.tags.map((t) => (
                      <span class="post-tag">{t}</span>
                    ))}
                  </span>
                </div>
              </a>
            ))
          }
        </div>

        {posts.length === 0 && <p class="empty">No posts yet. Check back soon.</p>}
      </div>
    </section>
  </main>

  <footer>
    <div class="frame foot">
      <p>&copy; 2026 Marko Stankovic</p>
      <a class="foot-link" href="/">back to home</a>
    </div>
  </footer>
</BaseLayout>

<style>
  .frame {
    max-width: 1000px;
    margin: 0 auto;
    padding-inline: 56px;
  }
  @media (max-width: 720px) {
    .frame { padding-inline: 28px; }
  }

  .head-band {
    padding-block: 84px 64px;
    background:
      linear-gradient(#1f1f1f80 1px, transparent 1px) 0 0 / 100% 96px,
      linear-gradient(90deg, #1f1f1f80 1px, transparent 1px) 0 0 / 96px 100%;
  }
  h1 {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: clamp(2rem, 5vw, 3.25rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--color-text-primary);
    margin: 0 0 14px;
  }
  .sub {
    color: var(--color-text-secondary);
    font-size: 17px;
    line-height: 1.7;
    max-width: 56ch;
    margin: 0;
  }

  .list-band {
    border-top: 1px solid var(--color-border);
    padding-block: 56px 96px;
  }

  .tag-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 40px;
  }
  .tag-btn {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-text-secondary);
    background: transparent;
    border: 1px solid var(--color-border-strong);
    padding: 6px 12px;
    cursor: pointer;
    transition: color 0.15s ease, border-color 0.15s ease, background-color 0.15s ease;
  }
  .tag-btn:hover { color: var(--color-text-primary); border-color: var(--color-text-muted); }
  .tag-btn.active {
    color: var(--color-bg);
    background: var(--color-accent);
    border-color: var(--color-accent);
  }

  .post-rows { border-top: 1px solid var(--color-border); }
  .post-row {
    display: grid;
    grid-template-columns: 130px 1fr;
    gap: 24px;
    padding: 22px 4px;
    border-bottom: 1px solid var(--color-border);
    text-decoration: none;
    transition: background-color 0.15s ease;
  }
  .post-row:hover { background: var(--color-surface); }
  .post-row.filtered-out { display: none; }
  .row-meta {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .post-date, .post-time {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-text-muted);
    white-space: nowrap;
  }
  .row-main { display: flex; flex-direction: column; gap: 8px; }
  .post-title {
    font-size: 17px;
    font-weight: 600;
    color: var(--color-text-primary);
    line-height: 1.35;
  }
  .post-row:hover .post-title { color: var(--color-accent); }
  .post-excerpt {
    font-size: 14px;
    color: var(--color-text-secondary);
    line-height: 1.6;
    max-width: 62ch;
  }
  .post-tags { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 2px; }
  .post-tag {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-text-muted);
  }
  .post-tag::before { content: "#"; color: var(--color-accent); }
  @media (max-width: 640px) {
    .post-row { grid-template-columns: 1fr; gap: 8px; }
    .row-meta { flex-direction: row; gap: 14px; }
  }

  .empty {
    font-family: var(--font-mono);
    font-size: 14px;
    color: var(--color-text-muted);
  }

  footer { border-top: 1px solid var(--color-border); }
  .foot {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: 8px;
    padding-block: 28px;
  }
  .foot p { margin: 0; font-size: 13px; color: var(--color-text-secondary); }
  .foot-link {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-text-muted);
    text-decoration: none;
  }
  .foot-link:hover { color: var(--color-text-secondary); }
</style>

<script>
  // Tag filter over the post rows
  const btns = document.querySelectorAll<HTMLButtonElement>(".tag-btn");
  const rows = document.querySelectorAll<HTMLElement>(".post-row");
  btns.forEach((btn) => {
    btn.addEventListener("click", () => {
      btns.forEach((b) => b.classList.remove("active"));
      btn.classList.add("active");
      const tag = btn.dataset.tag ?? "all";
      rows.forEach((row) => {
        const rowTags = (row.dataset.tags ?? "").split(",");
        row.classList.toggle("filtered-out", tag !== "all" && !rowTags.includes(tag));
      });
    });
  });
</script>
